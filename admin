async function loadAllTabs() {
  if (!db) { ['wisata','penginapan','kuliner'].forEach(t => renderTable(t)); return; }
  try {
    const all = await fetchAllDocs(true);
    const typeMap = {
      wisata:     ['wisata'],
      penginapan: ['penginapan','hotel','homestay'],
      kuliner:    ['kuliner','kuliner_cafe','cafe','restoran'],
    };
