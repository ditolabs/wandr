// ─── LOAD FROM FIREBASE ───────────────────────────────────────────────────────
// Cache semua data sekali dari Firebase, filter di client
let _allDocsCache = null;
let _allDocsCacheTime = 0;

async function fetchAllDocs(forceRefresh = false) {
  const now = Date.now();
  if (!forceRefresh && _allDocsCache && (now - _allDocsCacheTime) < 30000) {
    return _allDocsCache; // cache 30 detik
  }
  const snap = await db.collection('places').get();
  _allDocsCache = snap.docs.map(doc => ({ _id: doc.id, ...doc.data(), _source: 'firebase' }));
  _allDocsCacheTime = now;
  return _allDocsCache;
}

async function loadTab(type, forceRefresh = false) {
  if (!db) { renderTable(type); return; }
  try {
    const all = await fetchAllDocs(forceRefresh);
    // Filter by type — handle semua variasi nilai type di Firestore
    const typeMap = { wisata: ['wisata'], penginapan: ['penginapan','hotel','homestay'], kuliner: ['kuliner','kuliner_cafe','cafe','restoran'] };
    const validTypes = typeMap[type] || [type];
    state.data[type] = all.filter(d => validTypes.includes((d.type||'').toLowerCase()));
    state.loaded[type] = true;
    updateStats();
    renderTable(type);
  } catch(e) {
    toast('Gagal load ' + type + ': ' + e.message, 'err');
    console.error('loadTab error:', e);
    renderTable(type);
  }
}

function updateStats() {
  const all = [...state.data.wisata, ...state.data.penginapan, ...state.data.kuliner];
  const localAll = [...state.local.wisata, ...state.local.penginapan, ...state.local.kuliner];
  document.getElementById('stat-total').textContent   = all.filter(d=>d.status==='approved'||!d.status).length;
  document.getElementById('stat-pending').textContent = all.filter(d=>d.status==='pending').length;
  document.getElementById('stat-local').textContent   = localAll.length;
  document.getElementById('cnt-wisata').textContent      = state.data.wisata.length + state.local.wisata.length;
  document.getElementById('cnt-penginapan').textContent  = state.data.penginapan.length + state.local.penginapan.length;
  document.getElementById('cnt-kuliner').textContent     = state.data.kuliner.length + state.local.kuliner.length;
}

// ─── RENDER TABLE ─────────────────────────────────────────────────────────────
function renderTable(type) {
  const q    = (state.search[type]||'').toLowerCase();
  const fbData  = state.data[type]  || [];
  const lcData  = state.local[type] || [];
  const all  = [...lcData.map(d=>({...d,_source:'local'})), ...fbData];
  const filtered = q ? all.filter(d =>
    (d.nama||d.Nama||'').toLowerCase().includes(q) ||
    (d.kawasan||d.Kawasan||'').toLowerCase().includes(q) ||
    (d.kategori||d.Kategori||'').toLowerCase().includes(q)
  ) : all;

  const perPage = PER_PAGE;
  const total   = filtered.length;
  const page    = state.page[type];
  const start   = (page-1)*perPage;
  const rows    = filtered.slice(start, start+perPage);
  const tbody   = document.getElementById('tbody-'+type);

  if (rows.length === 0) {
    tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state"><div class="empty-icon">📭</div>Tidak ada data</div></td></tr>`;
  } else {
    tbody.innerHTML = rows.map(d => {
      const id     = d._id || d.Id || '—';
      const nama   = d.nama || d.Nama || '—';
      const kaw    = d.kawasan || d.Kawasan || '—';
      const kat    = d.kategori || d.Kategori || '—';
      const status = d._source === 'local' ? 'local' : (d.status || 'approved');
      const statLabel = status === 'local' ? '<span class="td-stat stat-local">lokal</span>'
        : status === 'pending' ? '<span class="td-stat stat-pending">pending</span>'
        : '<span class="td-stat stat-approved">✓</span>';
      const isLocal = d._source === 'local';
      return `<tr>
        <td class="td-id">${String(id).slice(0,10)}</td>
        <td class="td-nama">${nama}${isLocal?'<span class="badge-new">NEW</span>':''}</td>
        <td class="td-kaw">${kaw}</td>
        <td><span class="td-kat">${kat}</span></td>
        <td>${statLabel}</td>
        <td class="td-actions">
          <button class="action-btn" onclick="openEdit('${type}','${id}')">Edit</button>
          ${isLocal
            ? `<button class="action-btn push" onclick="pushSingle('${type}','${id}')">Push</button>`
            : `<button class="action-btn" onclick="approveDoc('${type}','${id}','${status}')">
                ${status==='pending'?'Approve':'Pending'}</button>`}
          <button class="action-btn del" onclick="deleteDoc('${type}','${id}')">Hapus</button>
        </td>
      </tr>`;
    }).join('');
  }

  // Pagination
  const pages = Math.ceil(total/perPage);
  const pag   = document.getElementById('pag-'+type);
  if (pages <= 1) { pag.innerHTML=''; return; }
  let html = `<span style="margin-right:8px">${start+1}–${Math.min(start+perPage,total)} dari ${total}</span>`;
  html += `<button class="page-btn" onclick="setPage('${type}',${page-1})" ${page<=1?'disabled':''}>‹</button>`;
  const lo = Math.max(1,page-2), hi = Math.min(pages,page+2);
  for (let i=lo;i<=hi;i++) html += `<button class="page-btn${i===page?' active':''}" onclick="setPage('${type}',${i})">${i}</button>`;
  html += `<button class="page-btn" onclick="setPage('${type}',${page+1})" ${page>=pages?'disabled':''}>›</button>`;
  pag.innerHTML = html;
}

function setPage(type, page) { state.page[type]=page; renderTable(type); }

// Search listeners
['wisata','penginapan','kuliner'].forEach(t => {
  const inp = document.getElementById('search-'+t);
  if (inp) inp.addEventListener('input', () => {
    state.search[t] = inp.value;
    state.page[t]   = 1;
    renderTable(t);
  });
  const btn = document.getElementById('btn-add-'+t);
