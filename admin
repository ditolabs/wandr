<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BWI Admin — Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #0a0f0a;
      --surface:  #111811;
      --surface2: #182018;
      --border:   rgba(255,255,255,.07);
      --border2:  rgba(255,255,255,.12);
      --accent:   #4ade80;
      --accent2:  #22c55e;
      --orange:   #f97316;
      --red:      #ef4444;
      --blue:     #60a5fa;
      --purple:   #c084fc;
      --text:     #e2f0e2;
      --muted:    #5a7a5a;
      --muted2:   #3a5a3a;
    }
    html { font-size: 14px; }
    body {
      background: var(--bg); color: var(--text);
      font-family: 'Space Grotesk', system-ui, sans-serif;
      min-height: 100vh; line-height: 1.5;
    }

    /* ── TOPBAR ── */
    #topbar {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,15,10,.92); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 20px; height: 54px;
      display: flex; align-items: center; gap: 16px;
    }
    .tb-brand { font-family: 'Space Mono', monospace; font-size: 13px; font-weight: 700; color: var(--accent); letter-spacing: .05em; }
    .tb-sep   { width: 1px; height: 20px; background: var(--border2); }
    .tb-title { font-size: 12px; color: var(--muted); }
    .tb-right { margin-left: auto; display: flex; align-items: center; gap: 10px; }
    .tb-user  { font-size: 11px; color: var(--muted); background: var(--surface2); padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); }
    .tb-logout { font-size: 11px; color: var(--red); background: rgba(239,68,68,.08); border: 1px solid rgba(239,68,68,.2); padding: 4px 12px; border-radius: 20px; cursor: pointer; transition: all .2s; font-family: inherit; }
    .tb-logout:hover { background: rgba(239,68,68,.15); }

    /* ── LAYOUT ── */
    #main { display: flex; min-height: calc(100vh - 54px); }
    #sidebar {
      width: 200px; flex-shrink: 0;
      background: var(--surface); border-right: 1px solid var(--border);
      padding: 16px 0; position: sticky; top: 54px; height: calc(100vh - 54px);
      overflow-y: auto;
    }
    .nav-section { padding: 0 12px; margin-bottom: 20px; }
    .nav-label   { font-size: 9px; font-weight: 700; letter-spacing: .1em; color: var(--muted2); text-transform: uppercase; margin-bottom: 6px; padding: 0 4px; }
    .nav-item    { display: flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: 8px; font-size: 12px; font-weight: 500; color: var(--muted); cursor: pointer; transition: all .15s; margin-bottom: 2px; border: 1px solid transparent; }
    .nav-item:hover { background: var(--surface2); color: var(--text); }
    .nav-item.active { background: rgba(74,222,128,.08); color: var(--accent); border-color: rgba(74,222,128,.15); }
    .nav-count { margin-left: auto; font-size: 10px; background: var(--surface2); padding: 1px 6px; border-radius: 10px; color: var(--muted); font-family: 'Space Mono', monospace; }
    .nav-item.active .nav-count { background: rgba(74,222,128,.12); color: var(--accent2); }

    #content { flex: 1; padding: 24px; overflow-x: hidden; }

    /* ── STATS ── */
    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 24px; }
    .stat-card  { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 16px; }
    .stat-val   { font-family: 'Space Mono', monospace; font-size: 28px; font-weight: 700; line-height: 1; margin-bottom: 4px; }
    .stat-lbl   { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }

    /* ── TOOLBAR ── */
    .toolbar { display: flex; gap: 8px; align-items: center; margin-bottom: 16px; flex-wrap: wrap; }
    .search-wrap { position: relative; flex: 1; min-width: 180px; }
    .search-wrap input { width: 100%; background: var(--surface); border: 1px solid var(--border2); color: var(--text); border-radius: 8px; padding: 8px 12px 8px 32px; font-size: 12px; font-family: inherit; outline: none; transition: border-color .2s; }
    .search-wrap input:focus { border-color: var(--accent2); }
    .search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 13px; pointer-events: none; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 8px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: inherit; border: none; transition: all .2s; white-space: nowrap; }
    .btn-primary { background: var(--accent2); color: #000; }
    .btn-primary:hover { background: var(--accent); }
    .btn-ghost   { background: var(--surface2); color: var(--text); border: 1px solid var(--border2); }
    .btn-ghost:hover { background: rgba(255,255,255,.07); }
    .btn-danger  { background: rgba(239,68,68,.1); color: var(--red); border: 1px solid rgba(239,68,68,.2); }
    .btn-danger:hover { background: rgba(239,68,68,.2); }
    .btn-import  { background: rgba(96,165,250,.1); color: var(--blue); border: 1px solid rgba(96,165,250,.2); }
    .btn-export  { background: rgba(249,115,22,.1); color: var(--orange); border: 1px solid rgba(249,115,22,.2); }
    .btn-push    { background: rgba(192,132,252,.1); color: var(--purple); border: 1px solid rgba(192,132,252,.2); }
    .btn:disabled { opacity: .4; cursor: not-allowed; }

    /* ── TABLE ── */
    .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { background: var(--surface2); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--border); }
    td { padding: 10px 14px; border-bottom: 1px solid var(--border); font-size: 12px; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,.015); }
    .td-id    { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--muted); }
    .td-nama  { font-weight: 600; color: var(--text); max-width: 180px; }
    .td-kaw   { font-size: 11px; color: var(--muted); }
    .td-kat   { display: inline-block; font-size: 10px; background: var(--surface2); border: 1px solid var(--border2); padding: 2px 8px; border-radius: 12px; white-space: nowrap; }
    .td-stat  { display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 12px; font-weight: 600; }
    .stat-approved { background: rgba(74,222,128,.1); color: var(--accent); border: 1px solid rgba(74,222,128,.2); }
    .stat-pending  { background: rgba(249,115,22,.1); color: var(--orange); border: 1px solid rgba(249,115,22,.2); }
    .stat-local    { background: rgba(96,165,250,.1); color: var(--blue); border: 1px solid rgba(96,165,250,.15); }
    .td-actions { display: flex; gap: 4px; }
    .action-btn { background: none; border: 1px solid var(--border2); color: var(--muted); border-radius: 6px; padding: 3px 8px; font-size: 10px; cursor: pointer; font-family: inherit; transition: all .15s; }
    .action-btn:hover { border-color: var(--accent2); color: var(--accent); }
    .action-btn.del:hover { border-color: var(--red); color: var(--red); }
    .action-btn.push:hover { border-color: var(--purple); color: var(--purple); }

    /* ── MODAL ── */
    .modal-bg { position: fixed; inset: 0; background: rgba(0,0,0,.7); backdrop-filter: blur(4px); z-index: 200; display: flex; align-items: center; justify-content: center; padding: 20px; }
    .modal-bg.hidden { display: none; }
    .modal { background: var(--surface); border: 1px solid var(--border2); border-radius: 16px; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; padding: 24px; }
    .modal-title { font-size: 16px; font-weight: 700; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; }
    .modal-close { background: none; border: none; color: var(--muted); font-size: 18px; cursor: pointer; }
    .form-row { margin-bottom: 14px; }
    .form-label { display: block; font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 6px; }
    .form-input, .form-select, .form-textarea {
      width: 100%; background: var(--surface2); border: 1px solid var(--border2); color: var(--text);
      border-radius: 8px; padding: 9px 12px; font-size: 13px; font-family: inherit; outline: none;
      transition: border-color .2s; direction: ltr; text-align: left;
    }
    .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--accent2); }
    .form-select option { background: #1a2e1a; }
    .form-textarea { resize: vertical; min-height: 80px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border); }

    /* ── IMPORT PANEL ── */
    .import-panel { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 24px; }
    .import-title { font-size: 13px; font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .drop-zone { border: 2px dashed var(--border2); border-radius: 10px; padding: 32px; text-align: center; cursor: pointer; transition: all .2s; }
    .drop-zone:hover, .drop-zone.drag-over { border-color: var(--accent2); background: rgba(74,222,128,.04); }
    .drop-zone-icon { font-size: 32px; margin-bottom: 10px; }
    .drop-zone-text { font-size: 13px; color: var(--muted); }
    .drop-zone-sub  { font-size: 11px; color: var(--muted2); margin-top: 4px; }

    /* ── TOAST ── */
    #toast { position: fixed; bottom: 20px; right: 20px; z-index: 999; display: flex; flex-direction: column; gap: 8px; }
    .toast-item { background: var(--surface); border: 1px solid var(--border2); border-radius: 10px; padding: 12px 16px; font-size: 12px; max-width: 280px; animation: slideIn .3s ease; display: flex; align-items: center; gap: 8px; }
    @keyframes slideIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
    .toast-ok  { border-left: 3px solid var(--accent); }
    .toast-err { border-left: 3px solid var(--red); }
    .toast-info{ border-left: 3px solid var(--blue); }

    /* ── LOGIN ── */
    #login-screen { position: fixed; inset: 0; background: var(--bg); z-index: 999; display: flex; align-items: center; justify-content: center; }
    #login-screen.hidden { display: none; }
    .login-box { background: var(--surface); border: 1px solid var(--border2); border-radius: 16px; padding: 32px; width: 320px; }
    .login-logo { font-family: 'Space Mono', monospace; font-size: 18px; font-weight: 700; color: var(--accent); margin-bottom: 4px; }
    .login-sub  { font-size: 11px; color: var(--muted); margin-bottom: 24px; }
    .login-err  { font-size: 11px; color: var(--red); margin-top: 10px; text-align: center; display: none; }

    /* ── BADGE ── */
    .badge-new { font-size: 9px; background: rgba(249,115,22,.15); color: var(--orange); border: 1px solid rgba(249,115,22,.3); padding: 1px 6px; border-radius: 10px; font-weight: 700; margin-left: 4px; }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      #sidebar { display: none; }
      .stats-grid { grid-template-columns: 1fr 1fr; }
      .form-grid { grid-template-columns: 1fr; }
    }
    .empty-state { text-align: center; padding: 48px 20px; color: var(--muted); }
    .empty-icon  { font-size: 36px; margin-bottom: 12px; opacity: .5; }
    .pagination  { display: flex; align-items: center; gap: 6px; margin-top: 14px; justify-content: flex-end; font-size: 12px; color: var(--muted); }
    .page-btn    { background: var(--surface); border: 1px solid var(--border2); color: var(--text); border-radius: 6px; padding: 4px 10px; cursor: pointer; font-family: inherit; font-size: 12px; transition: all .15s; }
    .page-btn:hover  { border-color: var(--accent2); color: var(--accent); }
    .page-btn.active { background: rgba(74,222,128,.1); border-color: var(--accent2); color: var(--accent); }
    .page-btn:disabled { opacity: .3; cursor: not-allowed; }
    .col-sort { cursor: pointer; user-select: none; }
    .col-sort:hover { color: var(--accent); }
    .push-progress { margin-top: 12px; }
    .push-bar-wrap { background: var(--surface2); border-radius: 4px; height: 6px; overflow: hidden; margin-top: 6px; }
    .push-bar { height: 100%; background: var(--accent2); transition: width .3s; border-radius: 4px; }
    .push-log { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--muted); margin-top: 8px; max-height: 80px; overflow-y: auto; line-height: 1.7; }
  </style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">BWI Admin</div>
    <div class="login-sub">Database Management Dashboard</div>
    <div class="form-row">
      <label class="form-label">Email</label>
      <input type="email" id="loginEmail" class="form-input" placeholder="admin@email.com" dir="ltr">
    </div>
    <div class="form-row">
      <label class="form-label">Password</label>
      <input type="password" id="loginPass" class="form-input" placeholder="••••••••">
    </div>
    <button class="btn btn-primary" style="width:100%;justify-content:center" id="btnLogin">Masuk</button>
    <div class="login-err" id="loginErr"></div>
  </div>
</div>

<!-- TOPBAR -->
<div id="topbar">
  <span class="tb-brand">BWI/ADMIN</span>
  <div class="tb-sep"></div>
  <span class="tb-title">Database Management</span>
  <div class="tb-right">
    <span class="tb-user" id="tb-user">—</span>
    <button class="tb-logout" id="btnLogout">Logout</button>
  </div>
</div>

<div id="main">
  <!-- SIDEBAR -->
  <div id="sidebar">
    <div class="nav-section">
      <div class="nav-label">Koleksi</div>
      <div class="nav-item active" data-tab="wisata">🗺️ Wisata <span class="nav-count" id="cnt-wisata">—</span></div>
      <div class="nav-item" data-tab="penginapan">🏨 Penginapan <span class="nav-count" id="cnt-penginapan">—</span></div>
      <div class="nav-item" data-tab="kuliner">🍜 Kuliner <span class="nav-count" id="cnt-kuliner">—</span></div>
    </div>
    <div class="nav-section">
      <div class="nav-label">Tools</div>
      <div class="nav-item" data-tab="import">📥 Import JSON</div>
      <div class="nav-item" data-tab="export">📤 Export</div>
    </div>
  </div>

  <!-- CONTENT -->
  <div id="content">
    <!-- STATS -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-val" id="stat-total" style="color:var(--accent)">—</div>
        <div class="stat-lbl">Total Records (aktif)</div>
      </div>
      <div class="stat-card">
        <div class="stat-val" id="stat-pending" style="color:var(--orange)">—</div>
        <div class="stat-lbl">Pending Approval</div>
      </div>
      <div class="stat-card">
        <div class="stat-val" id="stat-local" style="color:var(--blue)">—</div>
        <div class="stat-lbl">Data Lokal (belum push)</div>
      </div>
    </div>

    <!-- MAIN PANEL -->
    <div id="panel-wisata">
      <div class="toolbar">
        <div class="search-wrap">
          <span class="search-icon">⌕</span>
          <input type="text" id="search-wisata" placeholder="Cari wisata..." dir="ltr">
        </div>
        <button class="btn btn-ghost" id="filter-wisata" data-filter="">Semua Status</button>
        <button class="btn btn-primary" id="btn-add-wisata">+ Tambah</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th class="col-sort">Nama ↕</th>
              <th>Kawasan</th>
              <th>Kategori</th>
              <th>Status</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody id="tbody-wisata"></tbody>
        </table>
      </div>
      <div class="pagination" id="pag-wisata"></div>
    </div>

    <div id="panel-penginapan" style="display:none">
      <div class="toolbar">
        <div class="search-wrap">
          <span class="search-icon">⌕</span>
          <input type="text" id="search-penginapan" placeholder="Cari penginapan..." dir="ltr">
        </div>
        <button class="btn btn-primary" id="btn-add-penginapan">+ Tambah</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>ID</th><th>Nama</th><th>Kawasan</th><th>Kategori</th><th>Status</th><th>Aksi</th></tr>
          </thead>
          <tbody id="tbody-penginapan"></tbody>
        </table>
      </div>
      <div class="pagination" id="pag-penginapan"></div>
    </div>

    <div id="panel-kuliner" style="display:none">
      <div class="toolbar">
        <div class="search-wrap">
          <span class="search-icon">⌕</span>
          <input type="text" id="search-kuliner" placeholder="Cari kuliner/cafe..." dir="ltr">
        </div>
        <button class="btn btn-primary" id="btn-add-kuliner">+ Tambah</button>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>ID</th><th>Nama</th><th>Kawasan</th><th>Kategori</th><th>Status</th><th>Aksi</th></tr>
          </thead>
          <tbody id="tbody-kuliner"></tbody>
        </table>
      </div>
      <div class="pagination" id="pag-kuliner"></div>
    </div>

    <!-- IMPORT PANEL -->
    <div id="panel-import" style="display:none">
      <div class="import-panel">
        <div class="import-title">📥 Import dari JSON</div>
        <div class="drop-zone" id="dropZone">
          <div class="drop-zone-icon">📂</div>
          <div class="drop-zone-text">Drop file JSON di sini atau klik untuk pilih</div>
          <div class="drop-zone-sub">Format: {"wisata_banyuwangi":[...], "penginapan":[...], "kuliner_cafe":[...]}</div>
          <input type="file" id="fileInput" accept=".json" style="display:none">
        </div>
        <div id="import-preview" style="margin-top:16px;display:none">
          <div style="font-size:12px;font-weight:700;margin-bottom:10px;color:var(--accent)">📋 Preview Import</div>
          <div id="import-stats" style="font-size:12px;color:var(--muted);margin-bottom:12px"></div>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button class="btn btn-ghost" id="btn-import-local">💾 Simpan Lokal (draft)</button>
            <button class="btn btn-push" id="btn-import-push">🚀 Push ke Firebase</button>
            <button class="btn btn-danger" id="btn-import-cancel">Batal</button>
          </div>
          <div class="push-progress" id="push-progress" style="display:none">
            <div style="font-size:11px;color:var(--muted)" id="push-label">Pushing...</div>
            <div class="push-bar-wrap"><div class="push-bar" id="push-bar" style="width:0%"></div></div>
            <div class="push-log" id="push-log"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- EXPORT PANEL -->
    <div id="panel-export" style="display:none">
      <div class="import-panel">
        <div class="import-title">📤 Export Database</div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-bottom:16px">
          <div class="stat-card" style="display:flex;flex-direction:column;gap:8px">
            <div style="font-size:12px;font-weight:600">Export Semua</div>
            <div style="font-size:11px;color:var(--muted)">Wisata + Penginapan + Kuliner dari Firebase</div>
            <button class="btn btn-export" style="margin-top:auto" id="btn-export-all">📤 Export JSON</button>
          </div>
          <div class="stat-card" style="display:flex;flex-direction:column;gap:8px">
            <div style="font-size:12px;font-weight:600">Export Wisata</div>
            <div style="font-size:11px;color:var(--muted)">Hanya data wisata (type: wisata)</div>
            <button class="btn btn-ghost" style="margin-top:auto" id="btn-export-wisata">Export</button>
          </div>
          <div class="stat-card" style="display:flex;flex-direction:column;gap:8px">
            <div style="font-size:12px;font-weight:600">Export Penginapan</div>
            <div style="font-size:11px;color:var(--muted)">Hanya data penginapan</div>
            <button class="btn btn-ghost" style="margin-top:auto" id="btn-export-penginapan">Export</button>
          </div>
          <div class="stat-card" style="display:flex;flex-direction:column;gap:8px">
            <div style="font-size:12px;font-weight:600">Export Kuliner</div>
            <div style="font-size:11px;color:var(--muted)">Hanya data kuliner & cafe</div>
            <button class="btn btn-ghost" style="margin-top:auto" id="btn-export-kuliner">Export</button>
          </div>
        </div>
        <div style="font-size:11px;color:var(--muted);padding:12px;background:var(--surface2);border-radius:8px;border:1px solid var(--border)">
          💡 Export mengambil langsung dari Firebase Firestore. File JSON yang dihasilkan kompatibel untuk re-import.
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL TAMBAH/EDIT -->
<div class="modal-bg hidden" id="modalEdit">
  <div class="modal">
    <div class="modal-title">
      <span id="modal-title-text">Tambah Data</span>
      <button class="modal-close" id="btnCloseModal">✕</button>
    </div>
    <div class="form-grid">
      <div class="form-row">
        <label class="form-label">Nama *</label>
        <input type="text" class="form-input" id="f-nama" placeholder="Nama tempat" dir="ltr">
      </div>
      <div class="form-row">
        <label class="form-label">Kawasan *</label>
        <select class="form-select" id="f-kawasan">
