});

// ─── EDIT / TAMBAH ────────────────────────────────────────────────────────────
function openEdit(type, id) {
  state.editType = type;
  let doc = null;
  if (id) {
    doc = [...state.data[type], ...state.local[type]].find(d => (d._id||d.Id) === id);
  }
  state.editDoc = doc;
  document.getElementById('modal-title-text').textContent = doc ? 'Edit Data' : 'Tambah '+capitalize(type);
  document.getElementById('f-nama').value    = doc?.nama || doc?.Nama || '';
  document.getElementById('f-kawasan').value = doc?.kawasan || doc?.Kawasan || '';
  document.getElementById('f-kategori').value= doc?.kategori || doc?.Kategori || '';
  document.getElementById('f-akses').value   = doc?.akses || doc?.Akses || 'Mulus';
  document.getElementById('f-catatan').value = doc?.catatan || doc?.Catatan || '';
  document.getElementById('f-maps').value    = doc?.maps || doc?.Maps || '';
  document.getElementById('f-lat').value     = doc?.lat || '';
  document.getElementById('f-lng').value     = doc?.lng || '';
  document.getElementById('f-status').value  = doc?.status || 'approved';
  document.getElementById('modalEdit').classList.remove('hidden');
}

document.getElementById('btnCloseModal').addEventListener('click', closeModal);
document.getElementById('btnCancelEdit').addEventListener('click', closeModal);
document.getElementById('modalEdit').addEventListener('click', e => { if(e.target===document.getElementById('modalEdit')) closeModal(); });
function closeModal() { document.getElementById('modalEdit').classList.add('hidden'); }

document.getElementById('btnSaveEdit').addEventListener('click', async () => {
  const nama = document.getElementById('f-nama').value.trim();
  if (!nama) { toast('Nama wajib diisi', 'err'); return; }
  const data = {
    nama, type: state.editType === 'kuliner' ? 'kuliner' : state.editType,
    kawasan:  document.getElementById('f-kawasan').value,
    kategori: document.getElementById('f-kategori').value.trim(),
    akses:    document.getElementById('f-akses').value,
    catatan:  document.getElementById('f-catatan').value.trim(),
    maps:     document.getElementById('f-maps').value.trim(),
    status:   document.getElementById('f-status').value,
    updatedAt: new Date().toISOString(),
  };
  const lat = parseFloat(document.getElementById('f-lat').value);
  const lng = parseFloat(document.getElementById('f-lng').value);
  if (!isNaN(lat)) data.lat = lat;
  if (!isNaN(lng)) data.lng = lng;

  const doc = state.editDoc;
  const type = state.editType;

  if (doc && doc._id && db && doc._source !== 'local') {
    // Update di Firebase
    try {
      await db.collection('places').doc(doc._id).update(data);
      const idx = state.data[type].findIndex(d=>d._id===doc._id);
      if (idx>=0) state.data[type][idx] = {...state.data[type][idx], ...data};
      toast('Data berhasil diupdate ✓');
    } catch(e) { toast('Gagal update: '+e.message, 'err'); return; }
  } else if (doc && doc._source === 'local') {
    // Update lokal
    const idx = state.local[type].findIndex(d=>(d._id||d.Id)===doc._id);
    if (idx>=0) state.local[type][idx] = {...state.local[type][idx], ...data};
    toast('Data lokal diupdate');
  } else {
    // Tambah baru
    if (db) {
      try {
        const ref = await db.collection('places').add(data);
        state.data[type].unshift({ _id:ref.id, ...data, _source:'firebase' });
        toast('Data berhasil ditambah ke Firebase ✓');
      } catch(e) {
        // Fallback: simpan lokal
        const localId = 'local_' + Date.now();
        state.local[type].unshift({ _id:localId, ...data, _source:'local' });
        toast('Simpan lokal (Firebase gagal: '+e.message+')', 'info');
      }
    } else {
      const localId = 'local_' + Date.now();
      state.local[type].unshift({ _id:localId, ...data, _source:'local' });
      toast('Simpan lokal (offline mode)', 'info');
    }
  }
  updateStats(); renderTable(type); closeModal();
});

// ─── APPROVE / PENDING TOGGLE ─────────────────────────────────────────────────
async function approveDoc(type, id, currentStatus) {
  if (!db) { toast('Firebase tidak tersambung', 'err'); return; }
  const newStatus = currentStatus === 'pending' ? 'approved' : 'pending';
  try {
    await db.collection('places').doc(id).update({ status: newStatus });
    const doc = state.data[type].find(d=>d._id===id);
    if (doc) doc.status = newStatus;
    toast(`Status diubah ke: ${newStatus}`);
    renderTable(type);
  } catch(e) { toast('Gagal: '+e.message, 'err'); }
}

// ─── DELETE ───────────────────────────────────────────────────────────────────
async function deleteDoc(type, id) {
  if (!confirm('Hapus data ini?')) return;
  // Cek lokal dulu
  const localIdx = state.local[type].findIndex(d=>(d._id||d.Id)===id);
  if (localIdx >= 0) {
    state.local[type].splice(localIdx, 1);
    toast('Data lokal dihapus');
    updateStats(); renderTable(type); return;
  }
  if (!db) { toast('Firebase tidak tersambung', 'err'); return; }
  try {
    await db.collection('places').doc(id).delete();
    state.data[type] = state.data[type].filter(d=>d._id!==id);
    toast('Data dihapus ✓');
    updateStats(); renderTable(type);
  } catch(e) { toast('Gagal hapus: '+e.message, 'err'); }
}

// ─── PUSH SINGLE LOCAL DOC ────────────────────────────────────────────────────
async function pushSingle(type, id) {
  if (!db) { toast('Firebase tidak tersambung', 'err'); return; }
  const doc = state.local[type].find(d=>(d._id||d.Id)===id);
  if (!doc) return;
  try {
    const { _id, _source, ...data } = doc;
    const ref = await db.collection('places').add(data);
    state.local[type] = state.local[type].filter(d=>(d._id||d.Id)!==id);
    state.data[type].unshift({ _id:ref.id, ...data, _source:'firebase' });
    toast('Berhasil push ke Firebase ✓');
    updateStats(); renderTable(type);
  } catch(e) { toast('Gagal push: '+e.message, 'err'); }
}

// ─── IMPORT JSON ──────────────────────────────────────────────────────────────
const dropZone = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');
dropZone.addEventListener('click', () => fileInput.click());
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault(); dropZone.classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (file) parseImportFile(file);
});
fileInput.addEventListener('change', e => { if(e.target.files[0]) parseImportFile(e.target.files[0]); });

function parseImportFile(file) {
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const json = JSON.parse(e.target.result);
      state.importData = json;
      const wisata   = json.wisata_banyuwangi || json.wisata || [];
      const hotel    = json.penginapan || [];
      const kuliner  = json.kuliner_cafe || json.kuliner || [];
      const total    = wisata.length + hotel.length + kuliner.length;
      document.getElementById('import-stats').innerHTML =
        `<b>${total} records</b> ditemukan: 🗺️ ${wisata.length} wisata · 🏨 ${hotel.length} penginapan · 🍜 ${kuliner.length} kuliner`;
      document.getElementById('import-preview').style.display = '';
      document.getElementById('push-progress').style.display = 'none';
      toast(`File "${file.name}" berhasil dibaca`, 'info');
    } catch(err) {
      toast('File JSON tidak valid: '+err.message, 'err');
    }
  };
  reader.readAsText(file);
}

document.getElementById('btn-import-cancel').addEventListener('click', () => {
  state.importData = null;
  document.getElementById('import-preview').style.display = 'none';
  fileInput.value = '';
});

document.getElementById('btn-import-local').addEventListener('click', () => {
  if (!state.importData) return;
  const json = state.importData;
  const convert = (arr, type) => arr.map((d,i) => ({
    _id: 'local_import_'+type+'_'+i+'_'+Date.now(),
    _source: 'local',
    nama: d.Nama||d.nama, kawasan: d.Kawasan||d.kawasan,
    kategori: d.Kategori||d.kategori, akses: d.Akses||d.akses,
    catatan: d.Catatan||d.catatan, maps: d.Maps||d.maps,
    type, status: 'pending', lat: d.lat||null, lng: d.lng||null,
  }));
  state.local.wisata    = convert(json.wisata_banyuwangi||json.wisata||[], 'wisata');
  state.local.penginapan= convert(json.penginapan||[], 'penginapan');
  state.local.kuliner   = convert(json.kuliner_cafe||json.kuliner||[], 'kuliner');
  updateStats();
  ['wisata','penginapan','kuliner'].forEach(t => { state.loaded[t]=true; renderTable(t); });
  toast('Data disimpan lokal sebagai draft ✓', 'ok');
  document.getElementById('import-preview').style.display='none';
});

document.getElementById('btn-import-push').addEventListener('click', async () => {
  if (!state.importData) return;
  if (!db) { toast('Firebase tidak tersambung', 'err'); return; }
  const json  = state.importData;
  const items = [];
  (json.wisata_banyuwangi||json.wisata||[]).forEach(d => items.push({...d, _type:'wisata'}));
  (json.penginapan||[]).forEach(d => items.push({...d, _type:'penginapan'}));
  (json.kuliner_cafe||json.kuliner||[]).forEach(d => items.push({...d, _type:'kuliner'}));

  const prog  = document.getElementById('push-progress');
  const bar   = document.getElementById('push-bar');
  const log   = document.getElementById('push-log');
  const label = document.getElementById('push-label');
  prog.style.display = '';
  log.innerHTML = '';
  let done = 0, errors = 0;

  document.getElementById('btn-import-push').disabled = true;
  document.getElementById('btn-import-local').disabled = true;

  for (const d of items) {
    const { _type, Id, ...rest } = d;
    const data = {
      nama:     rest.Nama    || rest.nama    || '',
      kawasan:  rest.Kawasan || rest.kawasan || '',
      kategori: rest.Kategori|| rest.kategori|| '',
      akses:    rest.Akses   || rest.akses   || '',
      catatan:  rest.Catatan || rest.catatan || '',
      maps:     rest.Maps    || rest.maps    || '',
      type:     _type, status: 'approved',
      importedAt: new Date().toISOString(),
    };
    if (rest.lat) data.lat = parseFloat(rest.lat);
    if (rest.lng) data.lng = parseFloat(rest.lng);
        try {
      if (Id) {
        // Jika ada ID asli (seperti k1, w1) dari JSON, pakai ID tersebut dan paksa Timpa (Update)
        await db.collection('places').doc(String(Id)).set(data, { merge: true });
        log.innerHTML += `<span style="color:var(--blue)">✓ Tersimpan (Update): ${data.nama}</span>\n`;
        done++;
      } else {
        // Jika tidak ada ID bawaan, cek duplikat nama
        const dup = await db.collection('places')
          .where('nama','==',data.nama).where('type','==',_type).limit(1).get();
        if (!dup.empty) {
          // Update data jika nama sudah ada
          const docId = dup.docs[0].id;
          await db.collection('places').doc(docId).update(data);
          log.innerHTML += `<span style="color:var(--blue)">↻ Update: ${data.nama}</span>\n`;
          done++;
        } else {
          // Tambah baru jika benar-benar belum ada
          await db.collection('places').add(data);
          log.innerHTML += `<span style="color:var(--accent)">✓ Tambah Baru: ${data.nama}</span>\n`;
          done++;
        }
      }
    } catch(e) {
      log.innerHTML += `<span style="color:var(--red)">✗ ${data.nama}: ${e.message}</span>\n`;
      errors++;
    }
    log.scrollTop = log.scrollHeight;
    const pct = Math.round(((done+errors)/items.length)*100);
    bar.style.width = pct+'%';
    label.textContent = `Pushing... ${done+errors}/${items.length} (${pct}%)`;
    // Yield setiap 10 item agar UI tidak freeze
    if ((done+errors) % 10 === 0) await new Promise(r=>setTimeout(r,0));
  }

  label.textContent = `Selesai: ${done} berhasil, ${errors} error`;
  toast(`Push selesai: ${done} data berhasil`, done>0?'ok':'err');
  document.getElementById('btn-import-push').disabled = false;
  document.getElementById('btn-import-local').disabled = false;
  // Reload semua tab — force refresh cache
  _allDocsCache = null;
  state.loaded = { wisata:false, penginapan:false, kuliner:false };
  loadTab('wisata', true);
});

// ─── EXPORT ───────────────────────────────────────────────────────────────────
async function exportData(types) {
  if (!db) { toast('Firebase tidak tersambung', 'err'); return; }
  toast('Mengambil data dari Firebase...', 'info');
  try {
    const all = await fetchAllDocs(true); // selalu fresh saat export
    const typeMap = { wisata: ['wisata'], penginapan: ['penginapan','hotel','homestay'], kuliner: ['kuliner','kuliner_cafe','cafe','restoran'] };
    const result = {};
    for (const type of types) {
      const validTypes = typeMap[type] || [type];
      const docs = all.filter(d => validTypes.includes((d.type||'').toLowerCase()));
      const key = type === 'wisata' ? 'wisata_banyuwangi' : type === 'kuliner' ? 'kuliner_cafe' : type;
      result[key] = docs.map(d => ({
        Id: d._id, Nama: d.nama, Kawasan: d.kawasan, Kategori: d.kategori,
        Akses: d.akses, Catatan: d.catatan, Maps: d.maps, Status: d.status,
        ...(d.lat ? {lat: d.lat} : {}), ...(d.lng ? {lng: d.lng} : {})
      }));
    }
    const ts   = new Date().toISOString().slice(0,10);
    const blob = new Blob([JSON.stringify(result, null, 2)], {type:'application/json'});
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = `bwi-db-export-${ts}.json`;
    a.click(); URL.revokeObjectURL(url);
    const total = Object.values(result).reduce((s,arr) => s+arr.length, 0);
    toast(`Export ${total} records berhasil ✓`);
  } catch(e) {
    toast('Gagal export: ' + e.message, 'err');
  }
}

document.getElementById('btn-export-all').addEventListener('click', () => exportData(['wisata','penginapan','kuliner']));
document.getElementById('btn-export-wisata').addEventListener('click', () => exportData(['wisata']));
document.getElementById('btn-export-penginapan').addEventListener('click', () => exportData(['penginapan']));
document.getElementById('btn-export-kuliner').addEventListener('click', () => exportData(['kuliner']));

// ─── UTILS ────────────────────────────────────────────────────────────────────
function capitalize(s) { return s.charAt(0).toUpperCase()+s.slice(1); }

// ─── SCRIPT PEMBERSIH DATABASE OTOMATIS (Bisa dihapus jika sudah selesai) ───
async function jalankanPembersihan(tombol) {
  try {
    tombol.textContent = '⏳ Memproses...';
    tombol.disabled = true;

    const snap = await db.collection('places').get();
    let jumlahTerhapus = 0;

    for (const doc of snap.docs) {
      // Filter aman: ID acak Firebase panjangnya 20 karakter, ID asli kita <= 4 karakter
      if (doc.id.length > 10) {
        await doc.ref.delete();
        jumlahTerhapus++;
      }
    }

    alert(`🎉 Sukses! Berhasil membersihkan ${jumlahTerhapus} data kotor ber-ID acak.`);
    window.location.reload();
  } catch (e) {
    alert('Gagal membersihkan database: ' + e.message);
    tombol.textContent = '🧹 Bersihkan Data Kotor';
    tombol.disabled = false;
  }
}

function pasangTombolPembersih() {
  const container = document.querySelector('.tb-right');
  if (!container || document.getElementById('btnCleanKotor')) return;

  const btn = document.createElement('button');
  btn.id = 'btnCleanKotor';
  btn.textContent = '🧹 Bersihkan Data Kotor';
  btn.style.cssText = 'font-size: 11px; color: #fff; background: rgba(239,68,68,.85); border: 1px solid rgba(239,68,68,.3); padding: 4px 12px; border-radius: 20px; cursor: pointer; margin-right: 8px; font-family: inherit; font-weight: 500;';
  
  btn.addEventListener('click', () => {
    if (confirm('Apakah Anda yakin ingin menghapus SEMUA data ganda ber-ID acak panjang? Data asli (w1, p1, k1, dll) dijamin aman dan tidak akan terhapus.')) {
      jalankanPembersihan(btn);
    }
  });

  container.insertBefore(btn, container.firstChild);
}

