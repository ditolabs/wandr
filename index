// Load dari Firestore, fallback ke hardcoded jika gagal
async function loadDestinations() {
  showLoadingDest();
  if (!db) {
    console.warn('db null — pakai fallback');
    DESTINATIONS = DESTINATIONS_FALLBACK;
    return;
  }
  try {
    // Fetch semua places tanpa filter — hindari kebutuhan Firestore composite index
    const timeout = new Promise((_,rej) => setTimeout(()=>rej(new Error('timeout')), 10000));
    const query   = db.collection('places').get();
    const snap    = await Promise.race([query, timeout]);
    // Cache untuk dipakai loadPenginapanOptions (hindari fetch ulang)
    window._placesCache = snap.docs.map(doc => ({ id: doc.id, ...doc.data() }));

    const loaded = snap.docs
      .map(doc => mapToWandr(doc.id, doc.data()))
      .filter(Boolean);

    if (loaded.length > 0) {
      DESTINATIONS = loaded;
      console.log(`✓ Firebase: ${loaded.length} destinasi wisata dimuat dari ${snap.docs.length} total records`);
    } else {
      DESTINATIONS = DESTINATIONS_FALLBACK;
      console.warn('Firebase kosong atau semua pending, pakai fallback');
    }
  } catch(e) {
    DESTINATIONS = DESTINATIONS_FALLBACK;
    console.warn('Firebase gagal (' + e.message + '), pakai fallback');
  }
}

