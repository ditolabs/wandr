    render();
  });

  // Result — retry & restart
  const retry   = document.getElementById('btn-retry');
  const restart = document.getElementById('btn-restart');
  if (retry)   retry.addEventListener('click', () => { S.error=null; S.loading=true; render(); generate(); });
