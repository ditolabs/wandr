      transport:'', subTransport:'', durasi:'', gayaPerjalanan:'',
      penginapan:'', penginapanId:'', penginapanData:null,
      penginapanCustom:'', kulinerCustom:'', jumlahOrang:2,
      planDays:[], planBacklog:[],
      loading:false, itinerary:null, error:null,
    });
    S.destinations.clear();
    S.sewaLokal.clear();
    render();
  });
}

