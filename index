  // Step 2 — penginapan search
  const inpHotelSearch = document.getElementById('input-penginapan-search');
  if (inpHotelSearch) {
    inpHotelSearch.addEventListener('input', () => {
      S.penginapanSearchQuery = inpHotelSearch.value;
      if (S.penginapanSearchQuery && S.penginapanId) {
        S.penginapanId = ''; S.penginapanData = null; S.penginapan = '';
      }
      updateHotelSuggestions();
      updateNav();
    });
    inpHotelSearch.addEventListener('focus', () => {
      if (!S.penginapanId) updateHotelSuggestions();
    });
    inpHotelSearch.addEventListener('blur', () => {
      setTimeout(() => {
        const acEl = document.getElementById('hotel-autocomplete');
        if (acEl) acEl.style.display = 'none';
      }, 200);
    });
  }
  
  const btnClearHotel = document.getElementById('btn-clear-hotel');
