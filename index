<script>
// ─── FIREBASE CONFIG ─────────────────────────────────────────────────────────
let db = null, auth = null;
try {
  if (typeof firebase !== 'undefined') {
    if (!firebase.apps.length) {
      firebase.initializeApp({
        apiKey:            'AIzaSyCHWWjnxX5-Fk9-gRTZVwyC3WDDfnLPh_s',
        authDomain:        'banyuwangi-db.firebaseapp.com',
        projectId:         'banyuwangi-db',
        storageBucket:     'banyuwangi-db.firebasestorage.app',
        messagingSenderId: '973498690850',
        appId:             '1:973498690850:web:b2d67373174542167a497b',
      });
    }
    db   = firebase.firestore();
    auth = firebase.auth();
  }
} catch(e) {
  console.warn('Firebase init gagal:', e.message);
  db = null; auth = null;
}

// ─── AUTH — POLA BWI-APP-V3 (email + password) ───────────────────────────────
let isAdmin = false;

function setAdmin(val, email) {
  isAdmin = val;
  const btn = document.getElementById('btnLogin');
  if (val) {
    btn.textContent = '🔓';
    btn.title = 'Keluar dari Admin';
    btn.style.color = '#e07b39';
    btn.style.borderColor = 'rgba(224,123,57,.4)';
    document.getElementById('menu-username').textContent = email || 'Admin';
  } else {
    btn.textContent = '🔐';
    btn.title = 'Login admin';
    btn.style.color = '#6a8a6a';
    btn.style.borderColor = 'rgba(255,255,255,.08)';
  }
}

// Buka/tutup modal — persis pola bwi-app-v3
document.getElementById('btnLogin').addEventListener('click', (e) => {
  e.stopPropagation();
  if (isAdmin) {
    const m = document.getElementById('user-menu');
    m.style.display = m.style.display === 'block' ? 'none' : 'block';
  } else {
    const m = document.getElementById('modalLogin');
    m.style.display = 'flex';
    setTimeout(() => document.getElementById('loginEmail').focus(), 100);
  }
});
document.getElementById('closeLogin').addEventListener('click', () => {
  document.getElementById('modalLogin').style.display = 'none';
  document.getElementById('loginErr').style.display = 'none';
});
// Tutup user-menu kalau klik di luar
document.addEventListener('click', (e) => {
  const menu = document.getElementById('user-menu');
  const btn = document.getElementById('btnLogin');
  if (menu && btn && !menu.contains(e.target) && !btn.contains(e.target)) {
    menu.style.display = 'none';
  }
});

document.getElementById('modalLogin').addEventListener('click', (e) => {
  if (e.target === document.getElementById('modalLogin'))
    document.getElementById('modalLogin').style.display = 'none';
});
document.getElementById('loginPass').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') document.getElementById('btnDoLogin').click();
});

// Tombol Masuk
document.getElementById('btnDoLogin').addEventListener('click', async () => {
  const email = document.getElementById('loginEmail').value.trim();
  const pass  = document.getElementById('loginPass').value;
  const btn   = document.getElementById('btnDoLogin');
  const errEl = document.getElementById('loginErr');
  errEl.style.display = 'none';
  if (!email || !pass) { errEl.textContent = 'Email & password wajib diisi'; errEl.style.display = 'block'; return; }
  btn.textContent = '⏳ Memproses...'; btn.disabled = true;
  try {
    if (auth) {
      await auth.signInWithEmailAndPassword(email, pass);
      document.getElementById('modalLogin').style.display = 'none';
      document.getElementById('loginEmail').value = '';
      document.getElementById('loginPass').value = '';
    } else {
      setAdmin(true, email);
      document.getElementById('modalLogin').style.display = 'none';
    }
  } catch(e) {
    errEl.textContent = e.code === 'auth/wrong-password' ? '❌ Password salah'
      : e.code === 'auth/user-not-found'  ? '❌ Email tidak ditemukan'
      : e.code === 'auth/invalid-email'   ? '❌ Format email tidak valid'
      : '❌ ' + e.message;
    errEl.style.display = 'block';
  } finally { btn.textContent = 'Masuk'; btn.disabled = false; }
});

// User dropdown menu
document.getElementById('user-menu').addEventListener('click', (e) => e.stopPropagation());
document.addEventListener('click', () => document.getElementById('user-menu').classList.remove('open'));
document.getElementById('menu-logout').addEventListener('click', async () => {
  if (auth) await auth.signOut();
  else setAdmin(false);
  document.getElementById('user-menu').classList.remove('open');
});

// onAuthStateChanged — persis pola bwi-app-v3
if (auth) {
  auth.onAuthStateChanged(user => {
    if (user) setAdmin(true, user.email || user.displayName);
    else      setAdmin(false);
  });
}
</script>

<script>
// ─── KAWASAN → ZONE MAPPING ───────────────────────────────────────────────────
const KAWASAN_ZONE = {
  'Licin':'barat','Licin / Paltuding':'barat','Kalibendo':'barat',
  'Kalibaru':'barat','Songgon':'barat','Kemiren':'barat','Glenmore':'barat',
  'Wongsorejo':'utara','Banyuputih':'utara','Kalipuro':'utara',
  'Pesanggaran':'selatan','Tegaldlimo':'selatan','Purwoharjo':'selatan',
  'Muncar':'selatan','Benculuk':'selatan','Grajagan':'selatan',
  'Pusat Kota':'kota','Glagah':'kota','Rogojampi':'kota','Banyuwangi':'kota',
};

// ─── FIRESTORE DOC → WANDR DESTINATION ───────────────────────────────────────
function mapToWandr(id, d) {
  if (d.type !== 'wisata' || d.status === 'pending') return null;
  const nama = (d.nama||'').toLowerCase();
  const kat  = (d.kategori||'').toLowerCase();
  let cat = 'alam';
  if (kat.includes('pantai')||kat.includes('beach')||kat.includes('teluk')) cat='pantai';
  if (kat.includes('snorkel')||kat.includes('diving')||kat.includes('pulau')) cat='diving';
  if (kat.includes('kota')||kat.includes('budaya')||kat.includes('sejarah')) cat='budaya';
  const emojiBase = {alam:'🌿',pantai:'🌊',diving:'🤿',budaya:'🏛️'};
  const emojiOvr  = {'kawah ijen':'🌋','ijen':'🌋','air terjun':'💧','baluran':'🦌',
    'sukamade':'🐢','red island':'🏄','g-land':'🏄','menjangan':'🤿',
    'tabuhan':'🏝️','kawah wurung':'🏔️','green bay':'🌊','city tour':'🏛️'};
  let emoji = emojiBase[cat]||'🗺️';
  for (const [k,v] of Object.entries(emojiOvr)) { if(nama.includes(k)){emoji=v;break;} }
  const isIjen=nama.includes('ijen'), isSunset=nama.includes('red island')||nama.includes('pulau merah');
  const isNight=nama.includes('sukamade'), isCity=nama.includes('city tour');
  let bestTime='pagi';
  if(isSunset) bestTime='sore'; if(isNight) bestTime='malam'; if(isIjen) bestTime='dini hari';
  // Zone dari kawasan mapping, dengan override berbasis nama untuk yang sering salah
  const NAMA_ZONE_OVERRIDE = {
    'kawah wurung':'barat','kawah ijen':'barat','ijen':'barat','lider':'barat',
    'telunjuk':'barat','jagir':'barat','malangsari':'barat','beji':'barat',
    'baluran':'utara','menjangan':'utara','tabuhan':'utara','wongsorejo':'utara',
    'sukamade':'selatan','alas purwo':'selatan','red island':'selatan',
    'pulau merah':'selatan','green bay':'selatan','teluk ijo':'selatan',
    'g-land':'selatan','grajagan':'selatan','wedi ireng':'selatan',
  };
  let zone = KAWASAN_ZONE[d.kawasan] || 'kota';
  // Override jika nama mengandung keyword zona
  for (const [key, z] of Object.entries(NAMA_ZONE_OVERRIDE)) {
    if (nama.includes(key)) { zone = z; break; }
  }
  const dur  = isIjen?300:cat==='diving'?360:kat.includes('terjun')?120:180;

  // Auto-generate aliases dari nama Firestore supaya matching lebih toleran
  // Contoh: "Pura Beji Antaboga" → aliases: ['pura beji antaboga','beji antaboga','beji','antaboga']
  const namaWords = nama.split(' ').filter(w => w.length > 2);
  const autoAliases = new Set([nama]);
  // Tambah sub-kombinasi kata (tanpa kata depan seperti "pura","taman","air","pantai")
  const skipWords = new Set(['pura','taman','nasional','pantai','air','gua','goa','pulau','kebun','perkebunan','padang']);
  const meaningfulWords = namaWords.filter(w => !skipWords.has(w));
  if (meaningfulWords.length > 0) {
    autoAliases.add(meaningfulWords.join(' '));
    meaningfulWords.forEach(w => autoAliases.add(w));
    // Kombinasi dua kata berurutan
    for (let i = 0; i < meaningfulWords.length - 1; i++) {
      autoAliases.add(meaningfulWords[i] + ' ' + meaningfulWords[i+1]);
    }
  }

  return { id, name:d.nama, cat, emoji, desc:d.catatan||d.kategori||'', bestTime,
    zone, tiket:d.htm||0, dur, isIjen, isSunset, isNight, isCity,
    aliases: [...autoAliases],
    tips:d.catatan?`Akses ${d.akses||''}. ${d.catatan}`.trim():'', maps:d.maps||'',
    lat:d.lat||null, lng:d.lng||null };
}
