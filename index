function haversineKm(lat1,lng1,lat2,lng2) {
  const R=6371, dLat=(lat2-lat1)*Math.PI/180, dLng=(lng2-lng1)*Math.PI/180;
  const a=Math.sin(dLat/2)**2+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLng/2)**2;
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}

// Fuzzy match teks ke DESTINATIONS — split koma, cari tiap kata
function parseDestInput(text) {
  S.destinations.clear();
  const terms = text.split(',').map(s=>s.trim().toLowerCase()).filter(Boolean);
  terms.forEach(term => {
    if (!term) return;
    let bestMatch = null, bestScore = 0;
    DESTINATIONS.forEach(d => {
      const score = matchScore(term, d);
      if (score > bestScore) { bestScore = score; bestMatch = d; }
    });
    if (bestMatch && bestScore >= 50) S.destinations.add(bestMatch.id);
  });
}

// Score matching satu term ke satu destinasi
function matchScore(term, d) {
  const t = term.toLowerCase().trim();
  const n = d.name.toLowerCase();

  // 1. Exact name match
  if (n === t) return 100;

  // 2. Alias match — hanya kalau alias cukup spesifik (minimal 4 karakter dan bukan substring pendek)
  if (d.aliases) {
    for (const a of d.aliases) {
      if (a.length < 4) continue; // skip alias terlalu pendek
      if (a === t) return 98;
      // Alias sama persis dengan term atau term sama persis dengan alias
      if (t === a) return 98;
      // Alias mengandung term (term lebih spesifik)
      if (a.includes(t) && t.length >= 5) return 90;
      // Term mengandung alias — hanya kalau alias panjang (>=8 char) supaya tidak false positive
      // "alas purwo" (10 char) boleh, tapi "jepang" (6 char) jangan match "taman nasional alas purwo"
      if (t.includes(a) && a.length >= 8) return 85;
    }
  }

  // 3. Nama mengandung term (min 4 karakter)
  if (t.length >= 4 && n.includes(t)) return 80;

  // 4. Term mengandung nama penuh (min 5 karakter)
  if (n.length >= 5 && t.includes(n)) return 75;

  // 5. Word-level — hitung kata bermakna yang cocok
  const skipWords = new Set(['dan','yang','ke','di','dari','untuk','dengan','atau','taman','nasional','pantai','air','goa','gua','pulau','bukit','gunung','perkebunan']);
  const nWords    = n.split(' ').filter(w => w.length > 2 && !skipWords.has(w));
  const termWords = t.split(' ').filter(w => w.length > 2 && !skipWords.has(w));
  if (!nWords.length || !termWords.length) return 0;

  const hits = termWords.filter(tw => nWords.some(nw => nw === tw || nw.startsWith(tw) || tw.startsWith(nw)));

  // Hitung coverage: berapa banyak kata nama yang ter-cover oleh term
  const coverage = hits.length / nWords.length;
  const precision = hits.length / termWords.length;
  // Pakai harmonic mean (F1-score style) supaya harus cocok di kedua sisi
  const f1 = coverage + precision > 0 ? 2 * coverage * precision / (coverage + precision) : 0;
  return f1 >= 0.5 ? Math.round(f1 * 60) : 0;
}


// Load penginapan terdekat dari Firebase berdasarkan destinasi terpilih
async function loadPenginapanOptions() {
  if (!db) { S.penginapanOptions = []; S.allPenginapan = []; return; }
  try {
    // Pakai cache dari loadDestinations kalau ada, hindari fetch ulang
    let allDocs;
    if (window._placesCache) {
      allDocs = window._placesCache;
    } else {
      const snap = await db.collection('places').get();
      allDocs = snap.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      window._placesCache = allDocs;
    }

    const all = allDocs.filter(d => {
      const t = (d.type||'').toLowerCase();
      return ['penginapan','hotel','homestay','villa','guesthouse'].includes(t);
    });
    S.allPenginapan = all;

    // Hitung terdekat dari destinasi terpilih (jika ada koordinat)
    if (S.destinations.size > 0) {
      const selDests = DESTINATIONS.filter(d=>S.destinations.has(d.id));
      const lats = selDests.map(d=>d.lat).filter(Boolean);
      const lngs = selDests.map(d=>d.lng).filter(Boolean);
      if (lats.length > 0) {
        const cLat = lats.reduce((a,b)=>a+b,0)/lats.length;
        const cLng = lngs.reduce((a,b)=>a+b,0)/lngs.length;
        S.penginapanOptions = all
          .filter(d => d.lat && d.lng)
          .map(d => ({ ...d, dist: haversineKm(cLat,cLng,d.lat,d.lng) }))
          .sort((a,b)=>a.dist-b.dist)
          .slice(0, 6);
      } else {
        S.penginapanOptions = all.slice(0, 6);
      }
    } else {
      S.penginapanOptions = all.slice(0, 6);
    }
  } catch(e) {
    console.warn('loadPenginapanOptions gagal:', e.message);
    S.penginapanOptions = []; S.allPenginapan = [];
  }
}

