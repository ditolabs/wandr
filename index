        <div class="plan-col-body p-3 min-h-[80px]" id="bucket-day${i}">
          ${ids.map(id => id.startsWith('hotel_checkin_') ? hotelCard(parseInt(id.split('_')[2]), hotelNames[parseInt(id.split('_')[2])]||'Penginapan') : destCard(id)).join('')}
          ${ids.length===0?'<div class="text-xs text-gray-400 text-center py-6 italic">Seret destinasi ke sini</div>':''}
        </div>
      </div>`;
  }).join('');

  const depHTML = totalDays > 1 ? `
    <div class="bg-green-50 border border-green-200 rounded-3xl overflow-hidden opacity-60">
      <div class="flex items-center gap-3 px-4 py-3 border-b border-green-100">
        <span class="w-7 h-7 bg-green-600 text-white rounded-lg flex items-center justify-center text-xs font-bold">${totalDays}</span>
        <span class="font-bold text-sm text-green-800">Hari ${totalDays} — Kepulangan 🔒</span>
        <span class="text-[10px] text-green-500 ml-auto">Otomatis</span>
      </div>
      <div class="p-3 pointer-events-none">
        <div class="flex items-center gap-3 p-3 bg-white/60 border border-green-100 rounded-2xl">
          <span class="text-2xl">🚌</span>
          <div class="font-bold text-sm text-green-700">Perjalanan Pulang</div>
        </div>
      </div>
    </div>` : '';

  return `
    <h2 class="font-serif text-3xl font-bold text-dark mb-2 leading-tight">Susun Rute</h2>
    <p class="text-sm font-medium text-gray-400 mb-6">Tahan lalu seret destinasi ke hari yang diinginkan</p>
    <div class="flex justify-between items-center mb-4">
      <div class="text-xs font-semibold text-gray-400">
        ${S.destinations.size} destinasi · ${totalDays} hari
        ${S.planBacklog.length>0?`<span class="text-amber-500"> · ${S.planBacklog.length} belum dijadwalkan</span>`:''}
      </div>
      <button id="btn-reset-plan" class="text-[11px] text-gray-400 bg-white border border-gray-200 rounded-full px-3 py-1.5 font-semibold hover:bg-gray-50 transition shadow-sm">
        ↺ Saran Otomatis
      </button>
    </div>
    ${hotelNames.length>1?`<div class="bg-purple-50 border border-purple-200 rounded-2xl px-4 py-3 text-xs font-semibold text-purple-700 mb-4">
      💡 <b>Multi-penginapan terdeteksi</b> — kartu check-in bisa diseret ke hari pindah penginapan
    </div>`:''}
    <div class="planning-board flex flex-col gap-3">
      ${backlogHTML}${arrivalHTML}${actDayHTML}${depHTML}
    </div>`;
}

// ─── SORTABLEJS INIT ─────────────────────────────────────────────────────────
// Menggantikan native HTML5 drag-drop — jauh lebih smooth di mobile touch
let _sortableInstances = [];

function initSortableBoard() {
  // Destroy semua instance lama
  _sortableInstances.forEach(s => s.destroy());
  _sortableInstances = [];

  const containers = document.querySelectorAll('.plan-col-body');
  containers.forEach(col => {
    // Skip: locked departure day tidak perlu SortableJS
    if (col.closest('.plan-col.locked')) return;
    const inst = new Sortable(col, {
      group:            'wandr-board',
      animation:        280,
      easing:           'cubic-bezier(0.25, 1, 0.5, 1)',
      delay:            150,
      delayOnTouchOnly: true,
      fallbackTolerance: 5,
      scroll:           true,
      scrollSensitivity:80,
      scrollSpeed:      20,
      bubbleScroll:     true,
      forceFallback:    true,
      fallbackOnBody:   true,
      ghostClass:       'sortable-ghost',
      chosenClass:      'sortable-chosen',
      dragClass:        'sortable-drag',
      onEnd: () => readPlanFromDOM(),
    });
    _sortableInstances.push(inst);
  });
}

// ─── GENERATE (rule-based, no API) ──────────────────────────────────────────
function generate() {
  S.loading = true; S.itinerary = null; S.error = null;
  render();

  setTimeout(() => {
    try {
      // Jika planning board sudah diisi, pakai susunan manual
      if (S.planDays && S.planDays.some(d=>d.length>0)) {
        generateFromPlan(); return;
      }
      const selected = DESTINATIONS.filter(d=>S.destinations.has(d.id))
        .map(d=>({...d,...(DEST_EXT[d.id]||{})}));

      const [totalDays] = parseDurasi(S.durasi);
      const spotsPerDay = S.gayaPerjalanan==='santai' ? 2 : 3;
      const kota = S.kotaAsal==='Lainnya' ? S.kotaAsalCustom : S.kotaAsal;

      const days = [];

      // Day 1: Arrival
      days.push(injectArrivalExtras(buildArrivalDay(kota, S.transport, S.penginapan)));

      // Group by zone
      const byZone = {};
      selected.forEach(d=>{
        const z=d.zone||'kota';
        if(!byZone[z]) byZone[z]=[];
        byZone[z].push(d);
      });
      // Sort barat: Ijen first, then Kawah Wurung, then Jagir
      if(byZone.barat){
        const ord=['ijen','kawah_wurung','jagir'];
        byZone.barat.sort((a,b)=>ord.indexOf(a.id)-ord.indexOf(b.id));
      }
      // Sort selatan: Sukamade last (night activity)
      if(byZone.selatan){
        byZone.selatan.sort((a,b)=>(a.id==='sukamade'?1:0)-(b.id==='sukamade'?1:0));
      }

      let dayNum = 2;
      const lastDay = totalDays > 1 ? totalDays : totalDays;
      const actDayLimit = totalDays > 1 ? totalDays-1 : totalDays;

      ['barat','utara','selatan','kota'].forEach(zone=>{
        if(!byZone[zone]||dayNum>actDayLimit) return;
        const spots = byZone[zone];

        if(zone==='barat' && spots.some(s=>s.id==='ijen')) {
          // Ijen day: Ijen + 1 optional (eksplorasi only)
          const ijenSpot = spots.find(s=>s.id==='ijen');
          const others   = spots.filter(s=>s.id!=='ijen');
          const ijenGroup= S.gayaPerjalanan==='eksplorasi'&&others.length
            ? [ijenSpot, others[0]] : [ijenSpot];
          if(dayNum<=actDayLimit) { days.push(buildActivityDay(dayNum++,ijenGroup,zone,S)); }
          const remaining = S.gayaPerjalanan==='eksplorasi' ? others.slice(1) : others;
          for(let i=0;i<remaining.length;i+=spotsPerDay){
            if(dayNum<=actDayLimit) days.push(buildActivityDay(dayNum++,remaining.slice(i,i+spotsPerDay),zone,S));
          }
          return;
        }

        if(spots.some(s=>s.id==='sukamade')) {
          // Sukamade: its own day
          const sukamade = spots.find(s=>s.id==='sukamade');
          const others   = spots.filter(s=>s.id!=='sukamade');
          for(let i=0;i<others.length;i+=spotsPerDay){
            if(dayNum<=actDayLimit) days.push(buildActivityDay(dayNum++,others.slice(i,i+spotsPerDay),zone,S));
          }
          if(dayNum<=actDayLimit) days.push(buildActivityDay(dayNum++,[sukamade],zone,S));
          return;
        }

        for(let i=0;i<spots.length;i+=spotsPerDay){
          if(dayNum<=actDayLimit) days.push(buildActivityDay(dayNum++,spots.slice(i,i+spotsPerDay),zone,S));
        }
      });

      // Last day: Departure
      if(totalDays>1) days.push(buildDepartureDay(totalDays,kota,S.transport));

      S.itinerary = {
        summary: buildSummary(selected,totalDays,S.gayaPerjalanan,kota),
        totalDays,
        highlights: selected.slice(0,3).map(d=>d.name),
        estimatedBudget: calculateBudget(selected,S,totalDays),
        days: days.slice(0,totalDays),
        packingTips: buildPackingTips(selected),
        importantNotes: buildNotes(selected),
      };
    } catch(e) {
      S.error = 'Terjadi kesalahan: '+e.message;
      console.error(e);
    } finally {
      S.loading = false;
      render();
    }
  }, 800); // Loading animation agar terasa proses
}


// Generate itinerary berdasarkan susunan manual dari planning board
function generateFromPlan() {
  try {
    const kota = S.kotaAsal==='Lainnya' ? S.kotaAsalCustom : S.kotaAsal;
    const [totalDays] = parseDurasi(S.durasi);
    const allSelected = DESTINATIONS.filter(d=>S.destinations.has(d.id));
    const hotelNames  = getHotelNames();
    const days = [];

    // Hari 1: Kedatangan (selalu)
    days.push(injectArrivalExtras(buildArrivalDay(kota, S.transport, S.penginapan)));

    // Hari dari planning board
    S.planDays.forEach((allIds, i) => {
      const dayNum = i + 2;
      if (dayNum >= totalDays || allIds.length === 0) return;

      // Pisahkan hotel check-in vs destinasi wisata
      const hotelCheckIns = allIds
        .filter(id => id.startsWith('hotel_checkin_'))
        .map(id => {
          const idx = parseInt(id.split('_')[2]);
          return { id, name: `Check-in: ${hotelNames[idx]||'Penginapan'}`, hotelName: hotelNames[idx]||'Penginapan', type:'penginapan' };
        });
      const spots = allIds
        .filter(id => !id.startsWith('hotel_checkin_'))
        .map(id => DESTINATIONS.find(d=>d.id===id))
        .filter(Boolean)
        .map(d => ({...d,...(DEST_EXT[d.id]||{})}));

      // Kalau hanya hotel check-in tanpa wisata, lewati (check-in akan masuk di buildActivityDay dengan injeksi)
      if (spots.length === 0 && hotelCheckIns.length > 0) {
        const act = hotelCheckIns.map(h => ({
          time: '14:00', name: h.name, location: h.hotelName,
          duration: '1 jam', description: 'Check-in penginapan. Taruh barang dan istirahat sejenak.',
          tips: 'Siapkan dokumen booking.', estimatedCost: 0, type: 'penginapan',
        }));
        days.push({ day:dayNum, date_label:`Hari ${dayNum}`, title:'Check-in Penginapan', activities:sortActivities(act) });
        return;
      }
      if (spots.length === 0) return;

      const zone = spots[0]?.zone || 'kota';
      const builtDay = buildActivityDay(dayNum, spots, zone, S, { honorOrder: true });

      // Inject hotel check-in activities ke awal atau akhir hari
      if (hotelCheckIns.length > 0) {
        const checkinActs = hotelCheckIns.map(h => ({
          time: '14:00', name: h.name, location: h.hotelName,
          duration: '1 jam', description: 'Check-in penginapan baru.',
          tips: '', estimatedCost: 0, type: 'penginapan',
        }));
        builtDay.activities = sortActivities([...builtDay.activities, ...checkinActs]);
      }

      days.push(builtDay);
    });

    // Hari terakhir: Kepulangan (jika multi-hari)
    if (totalDays > 1) days.push(buildDepartureDay(totalDays, kota, S.transport));

    S.itinerary = {
      summary: buildSummary(allSelected, totalDays, S.gayaPerjalanan, kota),
      totalDays,
      highlights: allSelected.slice(0,3).map(d=>d.name),
      estimatedBudget: calculateBudget(allSelected, S, totalDays),
      days: days.slice(0, totalDays),
      packingTips: buildPackingTips(allSelected),
      importantNotes: buildNotes(allSelected),
    };
  } catch(e) {
    S.error = 'Terjadi kesalahan: ' + e.message;
    console.error(e);
  } finally {
    S.loading = false;
    render();
  }
}
