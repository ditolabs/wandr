}
function buildNotes(spots) {
  const n=[];
  if(spots.some(s=>s.id==='ijen'))     n.push('Kawah Ijen ditutup saat cuaca ekstrem — selalu cek update terbaru sebelum berangkat.');
  if(spots.some(s=>s.id==='sukamade')) n.push('Akses Sukamade bisa terputus di musim hujan.');
  if(spots.some(s=>['menjangan','tabuhan'].includes(s.id))) n.push('Perjalanan ke pulau tergantung kondisi laut.');
  return n.join(' ')||'Selalu cek kondisi cuaca dan jalan sebelum berangkat. Jaga kebersihan dan hormati alam Banyuwangi.';
}

// ─── PLANNING BOARD ENGINE ────────────────────────────────────────────────────

// Inisialisasi planDays dari auto-suggestion zone clustering
function initPlanDays() {
  const [totalDays] = parseDurasi(S.durasi);
  // actDays = hari aktif untuk drag (exclude hari 1 kedatangan dan hari terakhir kepulangan)
  // Tapi juga pastikan cukup slot untuk semua destinasi
  const selected  = DESTINATIONS.filter(d => S.destinations.has(d.id));
  const spotsPerDay = S.gayaPerjalanan === 'santai' ? 2 : 3;
  const minActDays  = Math.ceil(selected.length / spotsPerDay);
  const naturalAct  = Math.max(1, totalDays - (totalDays > 1 ? 2 : 0));
  // Pakai yang lebih besar antara natural dan minimum yang dibutuhkan
  // tapi tidak melebihi totalDays - 1 (sisakan 1 hari kepulangan)
  const actDays = Math.min(Math.max(naturalAct, minActDays), Math.max(1, totalDays - 1));
  S.planDays    = Array.from({length: actDays}, () => []);
  S.planBacklog = [];
  const byZone = {};
  selected.forEach(d => {
    const z = DEST_EXT[d.id]?.zone || d.zone || 'kota';
    if (!byZone[z]) byZone[z] = [];
    byZone[z].push(d.id);
  });
  if (byZone.barat) { const ord=['ijen','kawah_wurung','jagir']; byZone.barat.sort((a,b)=>ord.indexOf(a)-ord.indexOf(b)); }
  if (byZone.selatan) { byZone.selatan.sort((a,b)=>(a==='sukamade'?1:0)-(b==='sukamade'?1:0)); }
  let di = 0;
  ['barat','utara','selatan','kota'].forEach(zone => {
    if (!byZone[zone] || di >= actDays) return;
    const spots = byZone[zone];
    if (zone==='barat' && spots.includes('ijen')) {
      const ig = S.gayaPerjalanan==='eksplorasi' ? ['ijen',...spots.filter(s=>s!=='ijen').slice(0,1)] : ['ijen'];
      if (di<actDays) S.planDays[di++] = ig;
      const rem = spots.filter(s=>!ig.includes(s));
      if (rem.length>0 && di<actDays) S.planDays[di++] = rem;
      return;
    }
    if (spots.includes('sukamade')) {
      const others = spots.filter(s=>s!=='sukamade');
      for (let i=0;i<others.length;i+=spotsPerDay) if(di<actDays) S.planDays[di++]=others.slice(i,i+spotsPerDay);
      if (di<actDays) S.planDays[di++] = ['sukamade'];
      return;
    }
    for (let i=0;i<spots.length;i+=spotsPerDay) if(di<actDays) S.planDays[di++]=spots.slice(i,i+spotsPerDay);
  });
  S.planBacklog = selected.map(d=>d.id).filter(id=>!S.planDays.flat().includes(id));
}

// Baca state planning board dari DOM (setelah SortableJS menggeser kartu)
function readPlanFromDOM() {
  S.planDays = S.planDays.map((_,i) => {
    const el = document.getElementById(`bucket-day${i}`);
    return el ? [...el.querySelectorAll('.drag-item')].map(c=>c.dataset.id) : [];
  });
  // Baca juga arrival day (opsional)
  const arrEl = document.getElementById('bucket-day-arrival');
  S.planArrivalExtras = arrEl
    ? [...arrEl.querySelectorAll('.drag-item')]
        .map(c=>c.dataset.id)
        .filter(id => !id.startsWith('hotel_checkin_'))
    : [];
  const bEl = document.getElementById('bucket-unassigned');
  S.planBacklog = bEl
    ? [...bEl.querySelectorAll('.drag-item')]
        .map(c=>c.dataset.id)
        .filter(id => !id.startsWith('hotel_checkin_'))
    : [];
}

