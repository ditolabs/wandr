// ── Time helpers ─────────────────────────────────────────────────────────────
function addMin(t, m) {
  const [h,mn] = t.split(':').map(Number);
  const tot = h*60+mn+m;
  return `${String(Math.floor(tot/60)%24).padStart(2,'0')}:${String(tot%60).padStart(2,'0')}`;
}
function durLabel(m) {
  const h=Math.floor(m/60), mn=m%60;
  return h&&mn?`${h} jam ${mn} menit`:h?`${h} jam`:`${mn} menit`;
}
function pickRand(arr) { return arr[Math.floor(Math.random()*arr.length)]; }
function parseDurasi(v) {
  return {'1D':[1,0],'2D1N':[2,1],'3D2N':[3,2],'4D3N':[4,3],'5D4N':[5,4]}[v]||[2,1];
}

// ── Build kuliner activity ────────────────────────────────────────────────────
function buildMakan(waktu, zone, overrideTime) {
  const timeMap = { pagi:'07:00', siang:'12:30', malam:'19:00' };
  const labelMap = { pagi:'Sarapan', siang:'Makan Siang', malam:'Makan Malam' };
  const finalTime = overrideTime || timeMap[waktu];
  // Pakai kuliner custom user jika ada
  if (S.kulinerCustom && S.kulinerCustom.trim()) {
    return { time:finalTime, name:`${labelMap[waktu]} — ${S.kulinerCustom.trim()}`,
      location:S.kulinerCustom.trim(), duration:'1 jam',
      description:`${labelMap[waktu]} di ${S.kulinerCustom.trim()} — pilihan kuliner incaran kamu.`,
      tips:'Sesuaikan dengan jam operasional tempat makan.', estimatedCost:30000, type:'makan' };
  }
  // Pakai kuliner dari Firebase jika ada (terdekat dari penginapan terpilih)
  if (S.kulinerOptions && S.kulinerOptions.length > 0) {
    const k = pickRand(S.kulinerOptions);
    const timeMap = { pagi:'07:00', siang:'12:30', malam:'19:00' };
    const labelMap = { pagi:'Sarapan', siang:'Makan Siang', malam:'Makan Malam' };
    return {
      time: timeMap[waktu],
      name: `${labelMap[waktu]} — ${k.nama}`,
      location: k.nama,
      duration: '1 jam',
      description: `${labelMap[waktu]} di ${k.nama}. ${k.catatan||k.menu_andalan||k.kategori||''}`,
      tips: `±${Math.round(k.dist*1000)}m dari penginapan — bisa jalan kaki.`,
      estimatedCost: k.harga ? parseInt(String(k.harga).replace(/\D/g,''))||25000 : 25000,
      type: 'makan',
    };
  }
  const db = KULINER_DB[zone] || KULINER_DB.kota;
  const w  = pickRand(db);
  return {
    time: finalTime,
    name: `${labelMap[waktu]} — ${w.name}`,
    location: w.name,
    duration: '1 jam',
    description: `${labelMap[waktu]} dengan menu ${w.menu}. Warung lokal favorit di kawasan ini.`,
    tips: 'Datang agak awal kalau ramai. Harga terjangkau, rasa autentik.',
    estimatedCost: w.est,
    type: 'makan',
  };
}

// ── Day 1: Kedatangan ─────────────────────────────────────────────────────────
function buildArrivalDay(kota, transport, penginapan) {
  const isUmum = transport === 'umum';
  const subLabel = {kereta:'Kereta Api (Mutiara Timur/Sri Tanjung)',pesawat:'Pesawat',bus:'Bus PO'}[S.subTransport] || 'Kendaraan Umum';
  const jamTiba  = parseInt((S.waktuTiba||'10:00').split(':')[0]);
  const finalHotel = getFinalHotelName();
  const acts = [];

  // Transport ke BWI
  const berangkat = isUmum ? '07:00' : '09:00';
  const durTrans  = isUmum ? {kereta:'±6 jam',pesawat:'±2 jam',bus:'±8 jam'}[S.subTransport]||'±6 jam' : '±4–5 jam';
  const costTrans = {kereta:250000,pesawat:1500000,bus:150000}[S.subTransport] || (isUmum?200000:80000);
  acts.push({ time:berangkat, name:`Perjalanan dari ${kota} ke Banyuwangi`,
    location:kota, duration:durTrans,
    description: isUmum
      ? `Naik ${subLabel} dari ${kota} menuju Banyuwangi.`
      : `Berkendara dari ${kota}. Pastikan kendaraan prima dan tangki penuh.`,
    tips: isUmum ? 'Pesan tiket minimal H-7. Bawa bekal ringan.' : 'Istirahat di rest area setiap 2 jam.',
    estimatedCost:costTrans, type:'transport' });

  // Logika berdasarkan jam tiba
  if (jamTiba < 11) {
    // Tiba pagi → bisa aktivitas ringan dulu
    acts.push({ time:S.waktuTiba, name:'Tiba di Banyuwangi',
      location: isUmum ? 'Stasiun/Bandara Banyuwangi' : 'Banyuwangi',
      duration:'30 menit', description:'Selamat datang di Banyuwangi! 🎉',
      tips:'', estimatedCost:0, type:'transport' });
    acts.push({ time:addMin(S.waktuTiba,30), name:'Titip Tas & Sewa Kendaraan',
      location:'Locker Wangi / Area Stasiun', duration:'45 menit',
      description:'Titip koper di Locker Wangi agar jalan-jalan pagi leluasa sebelum jam check-in hotel.',
      tips:'Locker Wangi: lockerwangi.com | WA: 0851-4717-8692. Tarif ~25K/tas.',
      estimatedCost:25000, type:'aktivitas' });
    acts.push(buildMakan('pagi','kota'));
    acts.push({ time:addMin(S.waktuTiba,105), name:'Wisata Pagi — Pantai Boom / Taman Blambangan',
      location:'Pusat Kota Banyuwangi', duration:'2 jam',
      description:'Jalan santai di Pantai Boom atau Taman Blambangan. Nikmati suasana kota.',
      tips:'Santai saja, simpan energi.', estimatedCost:5000, type:'aktivitas' });
    acts.push({ time:'13:00', name:'Ambil Tas & Check-in Penginapan',
      location:finalHotel, duration:'1 jam',
      description:`Ambil kembali tas dari Locker Wangi, lalu check-in ${finalHotel}.`,
      tips:'', estimatedCost:0, type:'penginapan' });
    acts.push(buildMakan('malam','kota'));
  } else if (jamTiba >= 11 && jamTiba < 18) {
    // Tiba siang-sore → langsung check-in
    acts.push({ time:S.waktuTiba, name:'Tiba & Check-in Penginapan',
      location:finalHotel, duration:'1 jam',
      description:`Check-in ${finalHotel}. Istirahat dan eksplorasi santai sekitar penginapan.`,
      tips:'', estimatedCost:0, type:'penginapan' });
    acts.push({ time:addMin(S.waktuTiba,90), name:'Eksplorasi Ringan Kota',
      location:'Pusat Kota Banyuwangi', duration:'2 jam',
      description:'Jalan sore santai, beli oleh-oleh kecil, nikmati suasana kota.',
      tips:'', estimatedCost:5000, type:'aktivitas' });
    acts.push(buildMakan('malam','kota'));
  } else {
    // Tiba malam
    acts.push(buildMakan('malam','kota'));
    acts.push({ time:addMin(S.waktuTiba,45), name:'Check-in & Istirahat',
      location:finalHotel, duration:'Malam',
      description:'Tiba malam, langsung check-in dan istirahat. Perjalanan esok lebih seru!',
      tips:'', estimatedCost:0, type:'penginapan' });
  }

  return { day:1, date_label:'Hari 1', title:`Kedatangan dari ${kota}`, activities:sortActivities(acts) };
}

// Tambah destinasi ekstra dari arrival bucket ke hari 1
function injectArrivalExtras(arrivalDay) {
  const extras = (S.planArrivalExtras||[])
    .map(id => DESTINATIONS.find(d=>d.id===id))
    .filter(Boolean);
  if (extras.length === 0) return arrivalDay;
  // Sisipkan setelah aktivitas terakhir sebelum makan malam
  const insertBefore = arrivalDay.activities.findIndex(a=>a.type==='kuliner'&&a.name.toLowerCase().includes('malam'));
  const extraActs = extras.map((d,i) => {
    const ext = DEST_EXT[d.id]||{};
    return { time: addMin('15:30', i*60),
      name: d.name, location: d.name+', Banyuwangi',
      duration: durLabel(ext.dur||120),
      description: ext.desc||d.desc||'',
      tips: ext.tips||'', estimatedCost: ext.tiket||d.tiket||0, type:'aktivitas' };
  });
  if (insertBefore >= 0) {
    arrivalDay.activities.splice(insertBefore, 0, ...extraActs);
  } else {
    arrivalDay.activities.push(...extraActs);
  }
  // Sort ulang setelah inject
  arrivalDay.activities = sortActivities(arrivalDay.activities);
  return arrivalDay;
}

