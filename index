  const base = new Set(['Sunscreen SPF50+','Uang tunai (ATM terbatas di lokasi wisata)','Powerbank','Kartu identitas','Obat-obatan pribadi']);
  spots.forEach(s=>(PACKING_DB[s.id]||[]).forEach(t=>base.add(t)));
