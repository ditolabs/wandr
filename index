// ─── PARTIAL UPDATE STEP 0 ───────────────────────────────────────────────────
// Dipanggil saat user mengetik — update feedback tanpa re-render input,
// supaya cursor tidak loncat ke awal (penyebab teks terbalik di Android)
function updateDestFeedback() {
  const matched   = DESTINATIONS.filter(d=>S.destinations.has(d.id));
  const terms     = S.destInput.split(',').map(s=>s.trim()).filter(Boolean);
  const unmatched = terms.filter(t => !isTermMatched(t));

  // 1. Tags destinasi yang dikenali
  const tagsEl = document.getElementById('dest-tags-area');
  if (tagsEl) {
    if (matched.length > 0) {
      tagsEl.style.display = '';
      const tags = matched.map(d => `
        <div style="display:inline-flex;align-items:center;gap:6px;padding:7px 12px;
          background:rgba(224,123,57,.12);border:1.5px solid rgba(224,123,57,.4);
          border-radius:20px;margin:3px">
          <span>${d.emoji}</span>
          <span style="font-size:13px;font-weight:600;color:#e07b39">${esc(d.name)}</span>
          <span data-remove="${d.id}" style="cursor:pointer;color:#8fa08f;font-size:11px;
            margin-left:2px;padding:1px 3px;border-radius:50%">✕</span>
        </div>`).join('');
      document.getElementById('dest-tags-list').innerHTML = tags;
      // Re-attach remove listeners
      document.querySelectorAll('[data-remove]').forEach(el => el.addEventListener('click', () => {
        const id = el.dataset.remove;
        S.destinations.delete(id);
        const d = DESTINATIONS.find(x=>x.id===id);
        if (d) {
          const parts = S.destInput.split(',').map(s=>s.trim())
            .filter(s=>!s.toLowerCase().includes(d.name.toLowerCase().split(' ')[0]));
          S.destInput = parts.join(', ');
          const inp = document.getElementById('dest-input');
          if (inp) inp.value = S.destInput;
        }
        updateDestFeedback();
        updateNav();
      }));
    } else {
      tagsEl.style.display = 'none';
    }
  }

  // 2. Warning "tidak ditemukan"
  const warnEl = document.getElementById('dest-warn-area');
  if (warnEl) {
    warnEl.style.display = (unmatched.length > 0 && S.destInput) ? '' : 'none';
    if (unmatched.length > 0 && S.destInput) {
      warnEl.innerHTML = `⚠️ Tidak ditemukan: <em>${unmatched.join(', ')}</em><br>
        <span style="color:#6a8a6a">Coba: Kawah Ijen, TN Baluran, Red Island, Green Bay, TN Alas Purwo, Kawah Wurung…</span>`;
    }
  }

  // 3. Label "Atau pilih" / "Tambah lagi"
  const lblEl = document.getElementById('dest-suggest-label');
  if (lblEl) lblEl.textContent = matched.length > 0 ? 'Tambah lagi:' : 'Atau pilih dari sini:';

  // 4. Suggestions — hapus yang sudah dipilih
  const sugEl = document.getElementById('dest-suggestions');
  if (sugEl) {
    const suggestions = DESTINATIONS
      .filter(d=>!S.destinations.has(d.id))
      .slice(0,6)
      .map(d=>`<button data-suggest="${d.id}" style="background:rgba(255,255,255,.05);
        border:1px solid rgba(255,255,255,.1);color:#8fa08f;border-radius:16px;
        padding:5px 11px;font-size:11px;cursor:pointer;font-family:inherit;
        transition:all .2s;white-space:nowrap">${d.emoji} ${d.name}</button>`).join('');
    sugEl.innerHTML = suggestions;
    // Re-attach suggest listeners
    sugEl.querySelectorAll('[data-suggest]').forEach(el => el.addEventListener('click', () => {
      const d = DESTINATIONS.find(x=>x.id===el.dataset.suggest);
      if (!d) return;
      S.destinations.add(d.id);
      S.destInput = S.destInput ? S.destInput.trimEnd().replace(/,$/,'')+', '+d.name : d.name;
      const inp = document.getElementById('dest-input');
      if (inp) inp.value = S.destInput;
      parseDestInput(S.destInput);
      updateDestFeedback();
      updateNav();
    }));
  }

  // 5. Tombol clear (✕ di dalam input)
  const clearBtn = document.getElementById('btn-clear-input');
  if (S.destInput && !clearBtn) {
    // Tambahkan clear button jika belum ada
    const wrap = document.getElementById('dest-input')?.parentElement;
    if (wrap) {
      const sp = document.createElement('span');
      sp.id = 'btn-clear-input';
      sp.style.cssText = 'position:absolute;right:12px;top:50%;transform:translateY(-50%);cursor:pointer;color:#5a7a5a;font-size:16px;padding:4px';
      sp.textContent = '✕';
      sp.addEventListener('click', () => {
        S.destInput = ''; S.destinations.clear();
        const inp = document.getElementById('dest-input');
        if (inp) { inp.value = ''; inp.focus(); }
        updateDestFeedback(); updateNav();
        const cb = document.getElementById('btn-clear-input');
        if (cb) cb.remove();
      });
      wrap.appendChild(sp);
    }
  } else if (!S.destInput && clearBtn) {
    clearBtn.remove();
  }
}

// Partial update suggestions penginapan (tanpa re-render step 2)
function updateHotelSuggestions() {
  const q    = (S.penginapanSearchQuery||'').toLowerCase();
  const all  = S.allPenginapan || [];
  const sel  = S.penginapanDataList || [];

  const filtered = q.length >= 1
    ? all.filter(p => {
        const n = (p.nama||'').toLowerCase();
        return n.includes(q)||(p.kawasan||'').toLowerCase().includes(q);
      }).slice(0, 8)
    : (q==='' && sel.length===0 ? S.penginapanOptions.slice(0,5) : []);

  const acEl = document.getElementById('hotel-autocomplete');
  if (acEl) {
    const show = q.length>=1 || (q===''&&sel.length===0&&S.penginapanOptions.length>0);
    acEl.style.display = show ? '' : 'none';
    acEl.innerHTML = filtered.length > 0
      ? filtered.map(p => {
          const alreadySel = sel.some(s=>s.id===p.id);
          const distTxt = p.dist!=null?(p.dist<1?Math.round(p.dist*1000)+'m':p.dist.toFixed(1)+'km'):'';
          return `<div class="autocomplete-item${alreadySel?' active':''}" data-penginapan-ac="${p.id}">
            <span style="font-size:20px">${alreadySel?'✓':'🏨'}</span>
            <div style="flex:1;min-width:0">
              <div class="autocomplete-item-name">${esc(p.nama)}</div>
              <div class="autocomplete-item-sub">${p.kawasan||''}${distTxt?' · ~'+distTxt:''}${p.harga?' · Rp'+p.harga:''}</div>
            </div>
            ${alreadySel?'<span style="color:#e07b39;font-size:11px">Terpilih</span>':''}
          </div>`;
        }).join('')
      : '<div class="autocomplete-empty">Tidak ditemukan</div>';

    // Attach click listeners — mousedown supaya tidak kalah sama blur
    acEl.querySelectorAll('[data-penginapan-ac]').forEach(el => {
      el.addEventListener('mousedown', e => {
        e.preventDefault();
        const id  = el.dataset.penginapanAc;
        const p   = all.find(x=>x.id===id);
        if (!p) return;
        const already = sel.some(s=>s.id===id);
        if (already) {
          // Toggle off
          S.penginapanDataList = sel.filter(s=>s.id!==id);
          S.penginapanIds      = S.penginapanDataList.map(s=>s.id);
        } else {
          // Tambah ke list
          S.penginapanDataList = [...sel, p];
          S.penginapanIds      = S.penginapanDataList.map(s=>s.id);
        }
        // Backward compat
        S.penginapanId   = S.penginapanIds[0] || '';
        S.penginapanData = S.penginapanDataList[0] || null;
        S.penginapan     = S.penginapanIds.length > 0 ? 'firebase' : '';
        S.penginapanSearchQuery = '';
        // Load kuliner dari penginapan pertama
        const first = S.penginapanDataList[0];
        if (first?.lat && first?.lng) loadKulinerNearPenginapan(first.lat, first.lng);
        render();
      });
    });
  }
}


function render() {
  const c = document.getElementById('content');
  try {
    switch (S.step) {
      case 0: c.innerHTML = renderStep0(); break;
      case 1: c.innerHTML = renderStep1(); break;
      case 2: c.innerHTML = renderStep2(); break;
      case 3:
        if (S.loading || S.error || S.itinerary) {
          c.innerHTML = renderStep3();
        } else {
          c.innerHTML = renderPlanningBoard();
          requestAnimationFrame(() => initSortableBoard());
        }
        break;
    }
  } catch(e) {
    console.error('render() error:', e);
    c.innerHTML = `<div style="padding:20px;color:#e07b39;font-size:13px">
      <b>⚠️ Error render:</b><br><pre style="white-space:pre-wrap;font-size:11px;color:#8fa08f;margin-top:8px">${esc(e.message)}\n${esc(e.stack||'')}</pre>
    </div>`;
  }
  updateProgress();
  updateNav();
  attachListeners();
}

// ─── LISTENERS ───────────────────────────────────────────────────────────────
function attachListeners() {
  const c = document.getElementById('content');

  // Step 0 — text input (PARTIAL UPDATE — tidak re-render agar cursor tidak reset)
  const destInput = document.getElementById('dest-input');
  if (destInput) {
    destInput.addEventListener('input', () => {
      S.destInput = destInput.value;
      parseDestInput(S.destInput);
      updateDestFeedback(); // partial update, bukan render()
      updateNav();
    });
    destInput.focus();
  }
  // Clear button
  const btnClear = document.getElementById('btn-clear-input');
  if (btnClear) btnClear.addEventListener('click', () => {
    S.destInput=''; S.destinations.clear();
    const inp = document.getElementById('dest-input');
    if (inp) { inp.value = ''; inp.focus(); }
    updateDestFeedback(); updateNav();
  });
  // Remove tag
  c.querySelectorAll('[data-remove]').forEach(el => el.addEventListener('click', () => {
    const id = el.dataset.remove;
    S.destinations.delete(id);
    const d = DESTINATIONS.find(x=>x.id===id);
    if (d) {
      const parts = S.destInput.split(',').map(s=>s.trim()).filter(s=>!s.toLowerCase().includes(d.name.toLowerCase().split(' ')[0]));
      S.destInput = parts.join(', ');
      const inp = document.getElementById('dest-input');
      if (inp) inp.value = S.destInput;
    }
    updateDestFeedback(); updateNav();
  }));
  // Suggestion pills
  c.querySelectorAll('[data-suggest]').forEach(el => el.addEventListener('click', () => {
    const d = DESTINATIONS.find(x=>x.id===el.dataset.suggest);
    if (!d) return;
    S.destinations.add(d.id);
    S.destInput = S.destInput ? S.destInput.trimEnd().replace(/,$/,'')+', '+d.name : d.name;
    const inp = document.getElementById('dest-input');
    if (inp) inp.value = S.destInput;
    parseDestInput(S.destInput);
    updateDestFeedback(); updateNav();
  }));

  // Step 1 — kota asal
  const selKota = document.getElementById('sel-kota');
  if (selKota) selKota.addEventListener('change', () => {
    S.kotaAsal = selKota.value;
    S.kotaAsalCustom = '';
    render();
  });
  const inputKota = document.getElementById('input-kota-custom');
  if (inputKota) inputKota.addEventListener('input', () => {
    S.kotaAsalCustom = inputKota.value;
    updateNav();
  });

  // Step 0 — kuliner custom
  const kulCust = document.getElementById('input-kuliner-custom');
  if (kulCust) kulCust.addEventListener('input', () => { S.kulinerCustom = kulCust.value; });

   // Step 1 — transport
  c.querySelectorAll('[data-transport]').forEach(el => el.addEventListener('click', () => {
    S.transport = el.dataset.transport;
    S.sewaLokal.clear();
    if (S.transport !== 'umum') S.subTransport = '';
    render(); // Muat ulang UI agar warna Tailwind berubah
  }));

  // Step 1 — sewa lokal
  c.querySelectorAll('[data-sewa]').forEach(el => el.addEventListener('click', () => {
    const v = el.dataset.sewa;
    S.sewaLokal.has(v) ? S.sewaLokal.delete(v) : S.sewaLokal.add(v);
    render();
  }));

  // Step 1 — sub-transport (kereta/pesawat/bus)
  c.querySelectorAll('[data-sub]').forEach(el => el.addEventListener('click', () => {
    S.subTransport = el.dataset.sub;
    render();
  }));

  // Step 1 — jam tiba & pulang
  const inpTiba = document.getElementById('input-waktu-tiba');
  if (inpTiba) inpTiba.addEventListener('change', () => { S.waktuTiba = inpTiba.value; updateNav(); });
  const inpPulang = document.getElementById('input-waktu-pulang');
