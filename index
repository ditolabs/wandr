  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{font-size:16px;scroll-behavior:smooth}
    body{background-color:#E5DFD3;-webkit-font-smoothing:antialiased}
    ::-webkit-scrollbar{display:none}
    .step-labels{display:flex;justify-content:space-between;margin-bottom:12px;padding:0 4px}
    .step-label{font-size:10px;font-weight:700;color:#9CA3AF;text-transform:uppercase;letter-spacing:.05em;transition:all .3s}
    .step-label.active{color:#1C1C1E;font-weight:800}
    .step-label.done{color:#1C1C1E;opacity:.5}
    .progress-bar{height:4px;background:#E5E7EB;border-radius:4px;overflow:hidden;margin-bottom:30px}
    .progress-fill{height:100%;background:#1C1C1E;border-radius:4px;transition:width .5s cubic-bezier(.4,0,.2,1)}
    .btn-pri{background:#1C1C1E;color:white;border:none;border-radius:9999px;padding:14px 28px;font-family:'Inter',sans-serif;font-weight:700;font-size:14px;cursor:pointer;transition:all .2s;box-shadow:0 10px 25px rgba(0,0,0,.1);display:inline-flex;align-items:center;justify-content:center;gap:8px;white-space:nowrap}
    .btn-pri:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,0,0,.2)}
    .btn-pri:disabled{opacity:.4;cursor:not-allowed;box-shadow:none;transform:none}
    .btn-ghost{background:transparent;color:#6B7280;border:none;padding:14px 0;font-family:'Inter',sans-serif;font-weight:700;font-size:14px;cursor:pointer;transition:color .2s}
    .btn-ghost:hover{color:#1C1C1E}
    .btn-ghost.hidden{visibility:hidden;display:none!important}
    @keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}
    .animate-fade-in{animation:fadeIn .3s ease-out}
    .animate-slide-up{animation:slideUp .4s ease-out}
    .sortable-chosen{background:#F3F4F6!important;border-color:#1C1C1E!important;transform:scale(1.02);box-shadow:0 10px 25px rgba(0,0,0,.05)}
    .sortable-ghost{opacity:.3;border:2px dashed #1C1C1E!important;background:transparent!important}
    input,select,textarea{direction:ltr!important;text-align:left!important;outline:none!important}
    input:focus,select:focus,textarea:focus{border-color:#1C1C1E!important}
    /* Autocomplete light theme */
    .autocomplete-wrap{position:relative}
    .autocomplete-dropdown{position:absolute;top:calc(100% + 4px);left:0;right:0;z-index:100;background:white;border:1.5px solid #E5E7EB;border-radius:16px;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,.08);max-height:260px;overflow-y:auto}
    .autocomplete-item{padding:10px 14px;cursor:pointer;border-bottom:1px solid #F9FAFB;transition:background .15s;display:flex;align-items:center;gap:10px}
    .autocomplete-item:last-child{border-bottom:none}
    .autocomplete-item:hover,.autocomplete-item.active{background:#F3F4F6}
    .autocomplete-item-name{font-size:13px;font-weight:600;color:#1C1C1E}
    .autocomplete-item-sub{font-size:11px;color:#9CA3AF;margin-top:1px}
    .autocomplete-empty{padding:14px;text-align:center;font-size:12px;color:#9CA3AF;font-style:italic}
