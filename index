// ── Build activity day ─────────────────────────────────────────────────────────
function buildActivityDay(dayNum, spots, zone, form, opts={}) {
  const hasIjen = spots.some(s=>s.id==='ijen');
  const hasSukamade = spots.some(s=>s.id==='sukamade');

  // Sort: normal → sunset → night
  // Jika opts.honorOrder=true (dari planning board), hanya geser night activities ke belakang
  // tapi tetap pertahankan urutan relatif user
  const sorted = opts.honorOrder
    ? (() => {
        const normal  = spots.filter(s=>!DEST_EXT[s.id]?.isNight);
        const nightly = spots.filter(s=>DEST_EXT[s.id]?.isNight);
        return [...normal, ...nightly];
      })()
    : [...spots].sort((a,b) => {
        const score = s => (DEST_EXT[s.id]?.isSunset?10:0) + (DEST_EXT[s.id]?.isNight?20:0);
        return score(a)-score(b);
      });

  const acts = [];
  const distKm = ZONE_DIST[zone]||30;
  const transMin = form.transport==='pribadi_motor'
    ? Math.round(distKm/40*60) : Math.round(distKm/45*60);

  // ── IJEN DAY ──
  if (hasIjen) {
    acts.push({ time:'23:15', name:`Berangkat ke Kawah Ijen via ${S.subTransport==='kereta'?'DAMRI dari Stasiun BWI':'Kendaraan dari '+getFinalHotelName()}`,
      location:`${getFinalHotelName()} → Paltuding`,
      duration:'1 jam 15 menit',
      description:'Berangkat menuju Paltuding (gerbang Ijen). Bus DAMRI tersedia dari Stasiun Banyuwangi Kota tujuan Ijen.',
      tips:'Bawa masker gas N95, headlamp, jaket sangat tebal. Bus DAMRI: ~Rp15.000 dari stasiun.',
      estimatedCost:15000, type:'transport' });
    acts.push({ time:'00:30', name:'Tiba di Paltuding — Antri Tiket',
      location:'Pos Paltuding, Kawah Ijen', duration:'1 jam',
      description:'Tiba di gerbang Paltuding. Antri tiket masuk dan istirahat sejenak di warung sebelum trekking dimulai.',
      tips:'Siapkan KTP asli untuk tiket. Antrian bisa sangat panjang di akhir pekan.',
      estimatedCost:20000, type:'aktivitas' });
    acts.push({ time:'01:30', name:'Mulai Trekking Kawah Ijen',
      location:'Gerbang Paltuding → Puncak Kawah', duration:'1 jam 30 menit',
      description:'Trekking ±3km menuju puncak kawah. Nikmati langit berbintang. Semakin dekat puncak, tercium bau belerang — pasang masker!',
      tips:'Jaga pace, atur napas. Ikuti headlamp di depan. Jangan berlari.',
      estimatedCost:0, type:'aktivitas' });
    acts.push({ time:'03:00', name:'Kawah Ijen — Blue Fire & Sunrise',
      location:'Kawah Ijen, Banyuwangi', duration:'4 jam',
      description:'Trekking ~3km (±1.5 jam) menuju puncak. Saksikan fenomena blue fire unik sebelum subuh, dilanjutkan sunrise spektakuler di atas kawah sulfur.',
      tips:'Ikuti jalur resmi. Sewa masker gas di pos (Rp10K). Jangan turun ke kawah tanpa pemandu resmi.',
      estimatedCost:5000+10000, type:'aktivitas' });
    acts.push({ time:'07:00', name:'Turun & Sarapan di Sekitar Paltuding',
      location:'Warung sekitar Paltuding', duration:'1 jam 30 menit',
      description:'Turun dari kawah dan sarapan di warung sekitar Paltuding. Istirahat dan nikmati udara segar pegunungan.',
      tips:'Beli kopi hangat — sangat dibutuhkan setelah trekking dini hari.',
      estimatedCost:25000, type:'makan' });

    if (form.gayaPerjalanan==='santai') {
      // Ijen hangover rule: santai = rest the rest of the day
      acts.push({ time:'09:00', name:'Kembali ke Penginapan — Istirahat Wajib',
        location:'Penginapan', duration:'5 jam',
        description:'Kembali ke penginapan untuk istirahat total. Trekking dini hari Ijen sangat menguras energi — pemulihan fisik adalah prioritas.',
        tips:'Tidur siang adalah pilihan paling bijak. Jangan memforsir tubuh setelah Ijen.',
        estimatedCost:0, type:'istirahat' });
    } else {
      // Eksplorasi: boleh tambah 1 spot searah (Kawah Wurung atau Jagir)
      const extra = sorted.find(s=>s.id!=='ijen');
      if (extra) {
        const ext = DEST_EXT[extra.id]||{};
        acts.push({ time:'09:30', name: extra.name,
          location: extra.name+', Banyuwangi', duration: durLabel(ext.dur||120),
          description: ext.desc||'', tips: ext.tips||'',
          estimatedCost: ext.tiket||0, type:'aktivitas' });
      }
      acts.push({ time:'12:00', name:'Kembali & Istirahat Siang',
        location:'Penginapan', duration:'3 jam',
        description:'Kembali ke penginapan. Istirahat setelah Ijen tetap sangat dianjurkan meski gaya eksplorasi.',
        tips:'Tidur 1–2 jam akan membuat badan jauh lebih segar untuk malam hari.',
        estimatedCost:0, type:'istirahat' });
    }
    acts.push(buildMakan('malam','barat'));

  // ── SUKAMADE DAY ──
  } else if (hasSukamade) {
    acts.push(buildMakan('pagi', zone));
    acts.push({ time:'08:00', name:'Perjalanan Menuju Sukamade',
      location:'Rute menuju Sukamade', duration:'3–4 jam',
      description:'Perjalanan panjang menuju Sukamade melewati jalan lintas hutan. Jalur menantang terutama musim hujan.',
      tips:'Gunakan kendaraan 4WD atau motor trail. Cek kondisi jalan sehari sebelumnya.',
      estimatedCost:0, type:'transport' });
    acts.push({ time:'12:00', name:'Tiba & Eksplorasi Pantai Sukamade',
      location:'Pantai Sukamade', duration:'3 jam',
      description:'Tiba di Sukamade. Eksplor pantai di siang hari dan check-in penginapan sederhana di kawasan.',
      tips:'Penginapan sangat terbatas — wajib reservasi jauh-jauh hari.',
      estimatedCost:10000, type:'aktivitas' });
    acts.push(buildMakan('siang','selatan'));
    acts.push({ time:'20:00', name:'Program Malam — Penyu Hijau Bertelur',
      location:'Pantai Sukamade', duration:'2–3 jam',
      description:'Dipandu ranger, saksikan penyu hijau raksasa naik ke pantai untuk bertelur. Momen langka dan sangat emosional.',
      tips:'Ikuti instruksi ranger sepenuhnya. Dilarang menggunakan flash kamera. Gunakan senter dengan filter merah.',
      estimatedCost:50000, type:'aktivitas' });

  // ── REGULAR DAY ──
  } else {
    // Transport to zone
    if (distKm > 15) {
      const berangkat = addMin('07:00', -transMin-10);
      acts.push({ time: berangkat,
        name:`Berangkat menuju ${ZONE_LABEL_SHORT[zone]||zone}`,
        location:'Penginapan → Destinasi', duration: durLabel(transMin),
        description:`Berangkat menuju klaster destinasi hari ini. Jarak ±${distKm}km dari kota, tempuh ±${durLabel(transMin)}.`,
        tips:'Pastikan bahan bakar penuh. Sarapan ringan dulu sebelum berangkat.',
        estimatedCost:0, type:'transport' });
    }

    let cur = '07:00';
    const mainSpots = sorted.filter(s=>!DEST_EXT[s.id]?.isSunset&&!DEST_EXT[s.id]?.isNight);
    const sunsetSpots = sorted.filter(s=>DEST_EXT[s.id]?.isSunset);

    mainSpots.forEach((spot, i) => {
      const ext = DEST_EXT[spot.id]||{};
      acts.push({ time:cur, name:spot.name,
        location:spot.name+', Banyuwangi', duration:durLabel(ext.dur||180),
        description:ext.desc||spot.desc||'', tips:ext.tips||'',
        estimatedCost:ext.tiket||0, type:'aktivitas' });
      cur = addMin(cur, (ext.dur||180)+35);

      // Insert lunch roughly in the middle
      if (i===Math.floor((mainSpots.length-1)/2)) {
        const makan = buildMakan('siang', zone);
        makan.time = cur;
        acts.push(makan);
        cur = addMin(cur, 70);
      }
    });

    // Sunset spots always at 15:00
    sunsetSpots.forEach(spot => {
      const ext = DEST_EXT[spot.id]||{};
      acts.push({ time:'15:00', name:spot.name+' — Sunset',
        location:spot.name, duration:durLabel(ext.dur||180),
        description:ext.desc||'', tips:ext.tips||'',
        estimatedCost:ext.tiket||0, type:'aktivitas' });
    });

    // If only sunset spots and no lunch added yet
    if (mainSpots.length===0 && sunsetSpots.length>0) {
      acts.unshift(buildMakan('siang', zone));
    }

    acts.push(buildMakan('malam', zone));
    acts.push({ time:'21:00', name:'Istirahat di Penginapan',
      location:'Penginapan Banyuwangi', duration:'8 jam',
      description:'Istirahat yang cukup untuk mempersiapkan energi hari berikutnya.',
      tips:'Siapkan perlengkapan untuk besok malam ini agar tidak terburu-buru.',
      estimatedCost:0, type:'penginapan' });
  }

  // Day title
  const names = spots.map(s=>s.name);
  const title = names.length<=2 ? names.join(' & ') : `Eksplorasi ${ZONE_LABEL_SHORT[zone]||zone} (${names.length} Destinasi)`;
  return { day:dayNum, date_label:`Hari ${dayNum}`, title, activities:sortActivities(acts) };
}

// Convert "HH:MM" ke menit untuk sorting
function timeToMin(t) {
  if (!t || typeof t !== 'string') return 9999;
  const [h, m] = t.split(':').map(Number);
  return (h||0)*60 + (m||0);
}

// Sort activities dalam satu hari berdasarkan waktu
function sortActivities(acts) {
  return [...acts].sort((a,b) => timeToMin(a.time) - timeToMin(b.time));
}

const ZONE_LABEL_SHORT = { barat:'Barat/Ijen', utara:'Utara', selatan:'Selatan', kota:'Kota BWI' };

// ── Budget calculator ─────────────────────────────────────────────────────────
function calculateBudget(spots, form, totalDays) {
  const tiket   = spots.reduce((s,d)=>s+(DEST_EXT[d.id]?.tiket||0),0);
  const makan   = totalDays*3*27000;
  const nights  = Math.max(0,totalDays-1);
  const hotelEst= {hotel45:700000,hotel3:300000,hotel12:150000,homestay:80000,none:0,firebase:150000};
  const hotel   = (hotelEst[form.penginapan]||100000)*nights;
  const sewaEst = [...(form.sewaLokal||[])].reduce((s,v)=>s+({motor:120000,mobil_driver:500000,ojek:30000}[v]||0)*totalDays,0);
  const transPP = {kereta:250000,pesawat:1500000,bus:150000}[form.subTransport]
    || (form.transport==='pribadi_mobil'?400000:form.transport==='pribadi_motor'?150000:200000);
  const totalTransport = transPP + sewaEst;
  const min = tiket+makan+hotel+totalTransport;
  return {
    min: Math.round(min/1000)*1000,
    max: Math.round(min*1.35/1000)*1000,
    details: { transportasi:totalTransport, akomodasi:hotel, kuliner:makan, wisata:tiket },
    note:`Per orang · ${totalDays} hari · Belum termasuk oleh-oleh`,
  };
}

